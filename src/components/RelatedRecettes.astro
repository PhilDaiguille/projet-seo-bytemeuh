---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  currentId: string;
  currentCategory?: string;
  limit?: number;
}

const { currentId, currentCategory, limit = 3 } = Astro.props;

const all = await getCollection("recettes");

// Même catégorie d'abord (hors courante), puis les autres par date, sans doublon
const sameCategory = all
  .filter((r) => r.id !== currentId && r.data.category === currentCategory)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const others = all
  .filter((r) => r.id !== currentId && r.data.category !== currentCategory)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const related: CollectionEntry<"recettes">[] = [
  ...sameCategory,
  ...others,
].slice(0, limit);
---

{
  related.length > 0 && (
    <section class="related-section" aria-labelledby="related-recettes-heading">
      <div class="related-header">
        <h2 class="related-title" id="related-recettes-heading">
          <span class="section-title-accent" aria-hidden="true" />
          D'autres recettes qui pourraient vous plaire
        </h2>
        <a href="/blog/recettes/" class="related-link">
          Toutes les recettes
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <>
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </>
          </svg>
        </a>
      </div>
      <div class="related-grid">
        {related.map((recette) => (
          <article class="related-card">
            <a
              href={`/blog/recettes/${recette.id}/`}
              aria-label={`Recette : ${recette.data.title}`}
            >
              {recette.data.featuredImage && (
                <div class="related-card-image">
                  <Image
                    src={recette.data.featuredImage}
                    alt={recette.data.featuredImageAlt ?? recette.data.title}
                    width={400}
                    height={267}
                    loading="lazy"
                    quality={55}
                    decoding="async"
                  />
                  {recette.data.category && (
                    <span class="related-card-badge">
                      {recette.data.category}
                    </span>
                  )}
                </div>
              )}
              <div class="related-card-body">
                <div class="related-card-meta">
                  {recette.data.totalTime && (
                    <span>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>
                      {recette.data.totalTime
                        .replace("PT", "")
                        .replace("H", " h ")
                        .replace("M", " min")
                        .trim()}
                    </span>
                  )}
                  {recette.data.difficulty && (
                    <span>{recette.data.difficulty}</span>
                  )}
                </div>
                <h3 class="related-card-title">{recette.data.title}</h3>
                <p class="related-card-desc">{recette.data.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  )
}
