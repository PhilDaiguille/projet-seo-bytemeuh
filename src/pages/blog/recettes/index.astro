---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { slugify } from "../../../utils/seo";

const recettes = await getCollection("recettes");
const sorted = recettes.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const tagCounts: Record<string, number> = {};
recettes.forEach((r) => {
  (r.data.tags ?? []).forEach((tag) => {
    const s = slugify(tag);
    tagCounts[s] = (tagCounts[s] ?? 0) + 1;
  });
});

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: "https://bytemeuh.phildaiguille.fr/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: "https://bytemeuh.phildaiguille.fr/blog/",
        },
        {
          "@type": "ListItem",
          position: 3,
          name: "Recettes",
          item: "https://bytemeuh.phildaiguille.fr/blog/recettes/",
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Recettes Bytemeuh — Cuisine saine et gourmande"
  description="Découvrez toutes les recettes de Bytemeuh : burgers de bœuf, bao buns végans, poke bowls, ratatouille provençale et bien plus encore."
  canonical="https://bytemeuh.phildaiguille.fr/blog/recettes/"
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/">Blog</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li aria-current="page">Recettes</li>
    </ol>
  </nav>

  <div style="margin-bottom: var(--space-10);">
    <h1
      style="font-size: var(--text-4xl); margin-bottom: var(--space-3); letter-spacing: -0.03em;"
    >
      Recettes Bytemeuh
    </h1>
    <p
      style="font-size: var(--text-lg); color: var(--color-muted); max-width: 60rem;"
    >
      Toutes nos recettes : cuisine saine, plats végans, viandes françaises de
      qualité et spécialités du monde entier, préparées avec nos propres
      produits de ferme.
    </p>
  </div>

  <div
    style="display: flex; flex-wrap: wrap; gap: var(--space-3); margin-bottom: var(--space-8); padding: var(--space-4); background: var(--color-surface); border-radius: var(--radius-lg); border: 1px solid var(--color-border);"
  >
    <span
      style="font-size: var(--text-sm); font-weight: 600; color: var(--color-muted); align-self: center;"
      >Explorer :</span
    >
    <a
      href="/blog/recettes/cuisine/"
      style="padding: var(--space-2) var(--space-4); background: var(--color-primary); color: white; border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: var(--space-2);"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><circle cx="12" cy="12" r="10"></circle><line
          x1="2"
          y1="12"
          x2="22"
          y2="12"></line><path
          d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
        ></path></svg
      >
      Par cuisine
    </a>
    <a
      href="/blog/recettes/tag/"
      style="padding: var(--space-2) var(--space-4); background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: var(--space-2);"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path
          d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"
        ></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg
      >
      Par tag
    </a>
    <a
      href="/blog/recettes/categorie/"
      style="padding: var(--space-2) var(--space-4); background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: var(--space-2);"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><rect x="3" y="3" width="7" height="7"></rect><rect
          x="14"
          y="3"
          width="7"
          height="7"></rect><rect x="14" y="14" width="7" height="7"
        ></rect><rect x="3" y="14" width="7" height="7"></rect></svg
      >
      Par catégorie
    </a>
  </div>

  <div class="cards-grid">
    {
      sorted.map((recette) => (
        <article class="card">
          <a
            href={`/blog/recettes/${recette.id}/`}
            aria-label={`Recette : ${recette.data.title}`}
          >
            <div class="card-image">
              {recette.data.featuredImage && (
                <Image
                  src={recette.data.featuredImage}
                  alt={recette.data.featuredImageAlt ?? recette.data.title}
                  width={600}
                  height={375}
                  loading="lazy"
                  decoding="async"
                />
              )}
              <span class="card-badge badge-recipe">Recette</span>
            </div>
            <div class="card-body">
              <div class="card-meta">
                {recette.data.totalTime && (
                  <span class="card-meta-item">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                    {recette.data.totalTime
                      .replace("PT", "")
                      .replace("H", " h ")
                      .replace("M", " min")
                      .trim()}
                  </span>
                )}
                {recette.data.difficulty && (
                  <span class="card-meta-item">{recette.data.difficulty}</span>
                )}
                {recette.data.aggregateRating && (
                  <span class="card-meta-item">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="#f59e0b"
                      stroke="#f59e0b"
                      stroke-width="1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                    {recette.data.aggregateRating.ratingValue}
                  </span>
                )}
              </div>
              <h2 class="card-title">{recette.data.title}</h2>
              <p class="card-description">{recette.data.description}</p>
            </div>
            {recette.data.tags && recette.data.tags.length > 0 && (
              <div class="card-footer">
                <div class="card-tags">
                  {recette.data.tags.slice(0, 2).map((tag) => {
                    const tSlug = slugify(tag);
                    return tagCounts[tSlug] >= 2 ? (
                      <a
                        href={`/blog/recettes/tag/${tSlug}/`}
                        class="tag"
                        style="text-decoration: none;"
                      >
                        {tag}
                      </a>
                    ) : (
                      <span class="tag" style="text-decoration: none;">
                        {tag}
                      </span>
                    );
                  })}
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  style="color:var(--color-primary)"
                  aria-hidden="true"
                >
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </div>
            )}
          </a>
        </article>
      ))
    }
  </div>
</BaseLayout>
