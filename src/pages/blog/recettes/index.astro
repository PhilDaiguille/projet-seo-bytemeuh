---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const recettes = await getCollection('recettes');
const sorted = recettes.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://bytemeuh.phildaiguille.fr/' },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://bytemeuh.phildaiguille.fr/blog/' },
        { '@type': 'ListItem', position: 3, name: 'Recettes', item: 'https://bytemeuh.phildaiguille.fr/blog/recettes/' },
      ],
    },
  ],
};
---

<BaseLayout
  title="Recettes Bytemeuh — Cuisine saine et gourmande"
  description="Découvrez toutes les recettes de Bytemeuh : burgers de bœuf, bao buns végans, poke bowls, ratatouille provençale et bien plus encore."
  canonical="https://bytemeuh.phildaiguille.fr/blog/recettes/"
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </li>
      <li><a href="/blog/">Blog</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </li>
      <li aria-current="page">Recettes</li>
    </ol>
  </nav>

  <div style="margin-bottom: var(--space-10);">
    <h1 style="font-size: var(--text-4xl); margin-bottom: var(--space-3); letter-spacing: -0.03em;">Recettes Bytemeuh</h1>
    <p style="font-size: var(--text-lg); color: var(--color-muted); max-width: 60rem;">
      Toutes nos recettes : cuisine saine, plats végans, viandes françaises de qualité et spécialités du monde entier, préparées avec nos propres produits de ferme.
    </p>
  </div>

  <div class="cards-grid">
    {sorted.map((recette) => (
      <article class="card">
        <a href={`/blog/recettes/${recette.id}/`} aria-label={`Recette : ${recette.data.title}`}>
          <div class="card-image">
            {recette.data.featuredImage && (
              <Image
                src={recette.data.featuredImage}
                alt={recette.data.featuredImageAlt ?? recette.data.title}
                width={600}
                height={375}
                loading="lazy"
                decoding="async"
              />
            )}
            <span class="card-badge badge-recipe">Recette</span>
          </div>
          <div class="card-body">
            <div class="card-meta">
              {recette.data.totalTime && (
                <span class="card-meta-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {recette.data.totalTime.replace('PT','').replace('H',' h ').replace('M',' min').trim()}
                </span>
              )}
              {recette.data.difficulty && (
                <span class="card-meta-item">{recette.data.difficulty}</span>
              )}
              {recette.data.aggregateRating && (
                <span class="card-meta-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {recette.data.aggregateRating.ratingValue}
                </span>
              )}
            </div>
            <h2 class="card-title">{recette.data.title}</h2>
            <p class="card-description">{recette.data.description}</p>
          </div>
          {recette.data.tags && recette.data.tags.length > 0 && (
            <div class="card-footer">
              <div class="card-tags">
                {recette.data.tags.slice(0, 2).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary)" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          )}
        </a>
      </article>
    ))}
  </div>
</BaseLayout>
