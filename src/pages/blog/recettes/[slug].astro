---
import { getCollection, render } from "astro:content";
import RecetteLayout from "../../../layouts/RecetteLayout.astro";

export async function getStaticPaths() {
  const recettes = await getCollection("recettes");
  return recettes.map((recette) => ({
    params: { slug: recette.id },
    props: { recette },
  }));
}

const { recette } = Astro.props;
const { Content } = await render(recette);
---

<RecetteLayout recette={recette}>
  <Content />
</RecetteLayout>
