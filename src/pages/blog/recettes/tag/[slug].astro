---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { slugify } from "../../../../utils/seo";

export async function getStaticPaths() {
  const recettes = await getCollection("recettes");
  const tagCounts: Record<string, number> = {};

  recettes.forEach((r) => {
    (r.data.tags ?? []).forEach((tag) => {
      const s = slugify(tag);
      tagCounts[s] = (tagCounts[s] ?? 0) + 1;
    });
  });

  return Object.entries(tagCounts)
    .filter(([, count]) => count >= 2)
    .map(([slug]) => ({
      params: { slug },
    }));
}

const { slug } = Astro.params;

const recettes = await getCollection("recettes");
const filtered = recettes
  .filter((r) => (r.data.tags ?? []).some((t) => slugify(t) === slug))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

if (filtered.length === 0) {
  return Astro.redirect("/blog/recettes/");
}

const tagName = filtered[0].data.tags?.find((t) => slugify(t) === slug) ?? slug;

const SITE_URL = "https://bytemeuh.phildaiguille.fr";
const pageUrl = `${SITE_URL}/blog/recettes/tag/${slug}/`;

const tagData: Record<
  string,
  { title: string; intro: string; tips: string[]; editorial?: string }
> = {
  vegan: {
    title: "Recettes vegan",
    intro:
      "Le vegan, ce n'est pas une contrainte — c'est une découverte. Tofu, jack-fruit, pois chiches, quinoa : les protéines végétales regorgent de possibilités. En remplaçant l'animal par des ingrédients de ferme, on redécouvre des saveurs authentiques. Chez Bytemeuh, le végan est une démarche cohérente avec notre engagement pour une agriculture régénérative.",
    tips: [
      "Le tofu se marinde toujours : min 2h dans sauce soja + huile de sésame",
      "Le jack-fruit jeune doit être bien rincé pour éliminer le sel de conservation",
      "Les protéines végétales se combinent (riz + légumineuses) pour un profil complet",
    ],
  },
  healthy: {
    title: "Recettes healthy",
    intro:
      "Manger sain ne veut pas dire manger fade. Nos recettes healthy proof le contraire : avocat crémeux, mangue sucrée, patate douce réconfortante, quinoa protéiné. Une alimentation consciente qui ne sacrifie ni le goût ni le plaisir. Chaque plat Bytemeuh est pensé pour nutritional balance sans renoncer à la gourmandise.",
    tips: [
      "L'avocat s'ajoute en fin de préparation pour garder sa texture",
      "La patate douce caramelise mieux à chaleur haute en debut de cuisson",
      "Le quinoa se toast 2min avant cuisson pour un goût de noisette",
    ],
  },
  vegetarien: {
    title: "Recettes végétariennes",
    intro:
      "Le végétarisme, bien plus qu'une absence de viande, c'est une cuisine positive qui célèbre les légumes comme stars de l'assiette. Aubergines fondantes, courgettes grillées, poivrons confits : chaque légume devient protagoniste. Nos recettes montrent qu'un plat sans viande peut être complet, satisfaisant et profond.",
    tips: [
      "Les légumes d'été (aubergine, courgette) rééquilibrent les saveurs avec du sel et du temps",
      "Un bon fromage (feta, chèvre) remplace la viande comme source de protéine",
      "Les herbes fraîches transforment un plat banal en quelque chose de spécial",
    ],
  },
  "viande-francaise": {
    title: "Recettes viande française",
    intro:
      "La viande française est un patrimoine : races Charolaise, Limousine, Blond d'Aquitaine élevées en plein air, engraissées avec des fourrages locaux. Ce savoir-faire crée des steaks d'une tendreté incomparable. Bytemeuh travaille uniquement avec des élevages à moins de 200km, garantissant fraîcheur et traçabilité.",
    tips: [
      "Une viande de qualité se sale en fin de cuisson, pas au début",
      "Le bœuf se repose 5min après cuisson pour que les jus se redistribuent",
      "Couper contre le grain pour les morceaux moins tendres",
    ],
  },
  boeuf: {
    title: "Recettes au bœuf",
    intro:
      "Le bœuf est l'une des protéines les plus versatiles de la cuisine mondiale. Burgers juteux, kebabs parfumés, tacos épicés, ravioli réconfortants : chaque culture l'a sublimé à sa manière. La clé ? Choisir le bon morceau (bœuf à griller pour les tacos, haché 15% MG pour les burgers) et ne pas trop le cuire.",
    tips: [
      "Le bœuf haché se travaille froids pour une meilleure texture des galettes",
      "Pour les morceaux en dés, saisir d'abord à feu vif avant de mijoter",
      "Le bœuf se marie avec les épices du monde : cumin, paprika, cinq-épices",
    ],
  },
  "cuisine-asiatique": {
    title: "Recettes cuisine asiatique",
    intro:
      "La cuisine asiatique maîtrise comme nulle part ailleurs l'art de l'équilibre : salé, sucré, amer, umami, épicé. Le wok brûlant crée ce goût de \"wok hei\" irrésistible. Chaque technique (vapeur pour les buns, friture pour les ravioli croustillants, marinade longue pour le tofu) transforme des ingrédients simples en plats complexes.",
    tips: [
      "Le wok doit être brûlant avant d'ajouter les ingrédients — chauffez à vide 3 minutes",
      "Les sauces asiatiques (soja, huître) sont déjà salées — attention à la sursalaison",
      "Le riz jasmin se rince 3 fois avant cuisson pour éliminer l'amidon en excès",
    ],
  },
  "cuisine-italienne": {
    title: "Recettes cuisine italienne",
    intro:
      "La cuisine italienne est une affaire de produits et de techniques. Des pâtes al dente enrobées d'une sauce qui leur colle à l'âme, une pizza à la pâte fermentée 24h avec une croûte alvéolée, un risotto onctueux qui s'étale dans l'assiette : chaque plat italien célèbre la perfection dans la simplicité.",
    editorial: `
      <h2>La cuisine italienne : l'éloge de la simplicité technique</h2>
      <p>La cuisine italienne a cette particularité rare : ses plats les plus célèbres — carbonara, cacio e pepe, pizza margherita, risotto alla milanese — n'utilisent que 4 à 6 ingrédients. Mais leur maîtrise demande des années. C'est la philosophie inverse de la cuisine fusion ou moléculaire : la complexité est dans la technique, pas dans la liste d'ingrédients.</p>
      <p>La <strong>carbonara</strong>, par exemple, n'est faite que de spaghetti, guanciale, œufs entiers + jaunes, pecorino romano et poivre noir. Pas de crème — jamais. La sauce se forme grâce à l'émulsion des œufs avec l'eau de cuisson des pâtes et le gras du guanciale. C'est une technique précise qui exige de maîtriser la température exacte pour éviter que les œufs ne coagulent.</p>

      <h2>L'eau de cuisson : l'ingrédient secret des pâtes italiennes</h2>
      <p>L'eau de cuisson des pâtes est l'ingrédient le plus sous-estimé de la cuisine italienne. Chargée en amidon après la cuisson des pâtes, elle sert de liant naturel pour les sauces. En Italie, on dit qu'une sauce sans eau de cuisson est une sauce orpheline.</p>
      <p>La technique : avant d'égoutter vos pâtes, prélevez <strong>toujours une tasse d'eau de cuisson</strong>. Ajoutez-la en fin de cuisson de la sauce, cuillère par cuillère, en remuant pour créer cette texture crémeuse qui enrobe chaque brin de pasta. L'eau doit être salée comme la mer — les pâtes s'assaisonnent dans l'eau, pas dans l'assiette.</p>

      <h2>Les recettes de cuisine italienne chez Bytemeuh</h2>
      <p>Nos recettes italiennes respectent les codes de l'authenticité régionale tout en restant accessibles. Des pâtes maison aux sauces mijotées, chaque recette est accompagnée d'explications sur la technique et les pièges à éviter. L'Italie culinaire est un voyage sans fin — et Bytemeuh est votre guide de voyage.</p>
    `,
    tips: [
      "L'eau de cuisson des pâtes est votre meilleur allié pour lier une sauce",
      "Les pâtes se finissent toujours dans la sauce — jamais égouttées puis nappées",
      "La carbonara n'a pas de crème : les œufs + eau de cuisson créent la sauce",
      "Le pecorino romano et le parmesan ne se substituent pas — ils ont des profils très différents",
    ],
  },
  "street-food": {
    title: "Recettes street food",
    intro:
      "La street food, c'est la démocratie de la cuisine. Un taco à la main, un bao bun en marchant, un bowl à emporter : manger bien n'a pas besoin de salle. Ces plats de rue sont souvent les plus anciens — transmis de génération en génération parce qu'ils sont bons, pas parce qu'ils sont tendance.",
    tips: [
      "La street food se prépare en plusieurs étapes : préparez tout avant de commencer",
      "Les pickles sont essentiels : ils apportent du croquant et de l'acidité qui équilibre",
      'La incontournabe étape du "pliage" des buns prend du temps — entraînez-vous!',
    ],
  },
};

const tag = tagData[slug!] ?? {
  title: tagName,
  intro: `Découvrez nos recettes ${tagName.toLowerCase()}. Des plats savoureux préparés avec des produits de ferme Bytemeuh, dans le respect des traditions et des saisons.`,
  tips: [
    "Utilisez des ingrédients de qualité pour des résultats optimaux",
    "Adaptez les quantités selon le nombre de personnes",
    "N'hésitez pas à ajuster les épices selon vos goûts",
  ],
};

const allTags = [...new Set(recettes.flatMap((r) => r.data.tags ?? []))];

const tagCounts: Record<string, number> = {};
recettes.forEach((r) => {
  (r.data.tags ?? []).forEach((tag) => {
    const s = slugify(tag);
    tagCounts[s] = (tagCounts[s] ?? 0) + 1;
  });
});

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      name: `${tag.title} — Bytemeuh`,
      description: tag.intro,
      url: pageUrl,
      mainEntity: {
        "@type": "ItemList",
        itemListElement: filtered.map((r, i) => ({
          "@type": "ListItem",
          position: i + 1,
          url: `${SITE_URL}/blog/recettes/${r.id}/`,
        })),
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: `${SITE_URL}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: `${SITE_URL}/blog/`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: "Recettes",
          item: `${SITE_URL}/blog/recettes/`,
        },
        {
          "@type": "ListItem",
          position: 4,
          name: "Tags",
          item: `${SITE_URL}/blog/recettes/tag/`,
        },
        { "@type": "ListItem", position: 5, name: tag.title, item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${tag.title} — Bytemeuh`}
  description={`${filtered.length} recette${filtered.length > 1 ? "s" : ""} ${tagName.toLowerCase()} à découvrir. ${tag.intro.slice(0, 100)}...`}
  canonical={pageUrl}
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/">Blog</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/recettes/">Recettes</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/recettes/tag/">Tags</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li aria-current="page">{tag.title}</li>
    </ol>
  </nav>

  <header class="pseo-header">
    <span class="pseo-badge">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path
          d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"
        ></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg
      >
      Tag
    </span>
    <h1>{tag.title}</h1>
    <p class="pseo-intro">{tag.intro}</p>
  </header>

  <section class="pseo-recipes">
    <div class="cards-grid">
      {
        filtered.map((recette) => (
          <article class="card">
            <a
              href={`/blog/recettes/${recette.id}/`}
              aria-label={`Recette : ${recette.data.title}`}
            >
              <div class="card-image">
                {recette.data.featuredImage && (
                  <Image
                    src={recette.data.featuredImage}
                    alt={recette.data.featuredImageAlt ?? recette.data.title}
                    width={400}
                    height={267}
                    loading="lazy"
                    quality={55}
                    decoding="async"
                  />
                )}
                <span class="card-badge badge-recipe">Recette</span>
              </div>
              <div class="card-body">
                <div class="card-meta">
                  {recette.data.totalTime && (
                    <span class="card-meta-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>
                      {recette.data.totalTime
                        .replace("PT", "")
                        .replace("H", " h ")
                        .replace("M", " min")
                        .trim()}
                    </span>
                  )}
                  {recette.data.difficulty && (
                    <span class="card-meta-item">
                      {recette.data.difficulty}
                    </span>
                  )}
                  {recette.data.aggregateRating && (
                    <span class="card-meta-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="#f59e0b"
                        stroke="#f59e0b"
                        stroke-width="1"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                      </svg>
                      {recette.data.aggregateRating.ratingValue}
                    </span>
                  )}
                </div>
                <h2 class="card-title">{recette.data.title}</h2>
                <p class="card-description">{recette.data.description}</p>
              </div>
              {recette.data.tags && recette.data.tags.length > 0 && (
                <div class="card-footer">
                  <div class="card-tags">
                    {recette.data.tags.slice(0, 2).map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="color:var(--color-primary)"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              )}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  {
    tag.editorial && (
      <section
        class="pseo-editorial"
        aria-label={`À propos du tag ${tag.title}`}
      >
        <div class="pseo-editorial-content" set:html={tag.editorial} />
      </section>
    )
  }

  <section class="pseo-tips">
    <h2 id="tips-heading" class="pseo-section-title">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><circle cx="12" cy="12" r="10"></circle><line
          x1="12"
          y1="8"
          x2="12"
          y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg
      >
      Astuces {tag.title}
    </h2>
    <ul class="pseo-tips-list">
      {
        tag.tips.map((tip) => (
          <li>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
            {tip}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="pseo-related-cuisines">
    <h2 id="tags-heading" class="pseo-section-title">Autres tags</h2>
    <div class="pseo-tags-grid">
      {
        allTags.map((t) => {
          const tSlug = slugify(t);
          if (tSlug === slug) return null;
          if (tagCounts[tSlug] < 2) return null;
          return (
            <a href={`/blog/recettes/tag/${tSlug}/`} class="pseo-tag-chip">
              {t}
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
