---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import FaqSection from "../../../../components/FaqSection.astro";
import { slugify } from "../../../../utils/seo";

const recettes = await getCollection("recettes");
const tagCounts: Record<string, number> = {};

recettes.forEach((r) => {
  (r.data.tags ?? []).forEach((tag) => {
    const s = slugify(tag);
    tagCounts[s] = (tagCounts[s] ?? 0) + 1;
  });
});

const tagsWithCount = Object.entries(tagCounts)
  .filter(([, count]) => count >= 2)
  .map(([slug, count]) => ({
    slug,
    count,
    name:
      recettes
        .flatMap((r) => r.data.tags ?? [])
        .find((t) => slugify(t) === slug) ?? slug,
  }))
  .sort((a, b) => b.count - a.count);

const SITE_URL = "https://bytemeuh.phildaiguille.fr";

const faq = [
  {
    question: "À quoi servent les tags de recettes sur Bytemeuh ?",
    answer:
      "Les tags regroupent les recettes par thème transversal — vegan, healthy, cuisine du monde, street food — indépendamment de leur catégorie. Ils permettent de croiser les cuisines et de trouver rapidement une recette correspondant à une envie ou un régime alimentaire précis.",
  },
  {
    question: "Comment trouver uniquement des recettes véganes ?",
    answer:
      "Sélectionnez le tag « vegan » : il rassemble toutes nos recettes sans produit animal, venues de Chine, d'Inde, du Mexique ou de France. Le chiffre entre parenthèses indique le nombre de recettes associées à chaque tag.",
  },
  {
    question:
      "Un tag « healthy » signifie-t-il que la recette est pauvre en calories ?",
    answer:
      "Pas nécessairement. Le tag « healthy » identifie les plats pensés pour l'équilibre nutritionnel — bonne source de protéines, légumes de saison, matières grasses de qualité — sans forcément être hypocaloriques. Chaque fiche recette détaille ses informations nutritionnelles.",
  },
];

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      name: "Recettes par tag — Bytemeuh",
      description:
        "Explorez nos recettes par thème : vegan, healthy, sans viande, cuisine du monde. Chaque tag révèle une facette de notre cuisine.",
      url: `${SITE_URL}/blog/recettes/tag/`,
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: `${SITE_URL}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: `${SITE_URL}/blog/`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: "Recettes",
          item: `${SITE_URL}/blog/recettes/`,
        },
        {
          "@type": "ListItem",
          position: 4,
          name: "Tags",
          item: `${SITE_URL}/blog/recettes/tag/`,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Recettes par tag — Bytemeuh"
  description="Explorez nos recettes par thème : vegan, healthy, sans viande, cuisine du monde. Trouvez facilement le plat qui vous correspond."
  canonical={`${SITE_URL}/blog/recettes/tag/`}
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/">Blog</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/recettes/">Recettes</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li aria-current="page">Tags</li>
    </ol>
  </nav>

  <header class="pseo-header">
    <span class="pseo-badge">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path
          d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"
        ></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg
      >
      Thèmes
    </span>
    <h1>Recettes par tag</h1>
    <p class="pseo-intro">
      Chaque tag raconte une philosophie culinaire. Vegan pour ceux qui
      valorisent les protéines végétales, healthy pour les amateurs d'équilibre
      nutritionnel, cuisine du monde pour les globe-trotteurs gastronomes.
      Combinez les thèmes pour affiner votre recherche et découvrir de nouvelles
      idées de plats au fil de vos envies.
    </p>
  </header>

  <div
    class="pseo-tags-grid"
    style="margin: var(--space-8) 0; display: flex; flex-wrap: wrap; gap: var(--space-3);"
  >
    {
      tagsWithCount.map(({ slug, name, count }) => (
        <a
          href={`/blog/recettes/tag/${slug}/`}
          class="pseo-tag-chip"
          style="padding: var(--space-3) var(--space-5); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600; color: var(--color-text); text-decoration: none; transition: all 0.2s; display: flex; align-items: center; gap: var(--space-2);"
        >
          <span>{name}</span>
          <span style="font-size: var(--text-xs); color: var(--color-primary);">
            ({count})
          </span>
        </a>
      ))
    }
  </div>

  <div
    style="margin-top: var(--space-10); padding: var(--space-8); background: var(--color-surface); border-radius: var(--radius-lg); border: 1px solid var(--color-border);"
  >
    <h2
      style="font-size: var(--text-xl); font-weight: 800; margin-bottom: var(--space-4);"
    >
      Comment utiliser les tags ?
    </h2>
    <p
      style="color: var(--color-muted); margin-bottom: var(--space-4); line-height: 1.65;"
    >
      Les tags permettent d'explorer nos recettes selon des thèmes transversaux
      qui croisent les cuisines et les catégories. Le tag <strong>vegan</strong> regroupe
      des recettes venues de Chine, d'Inde, du Mexique et de France — des approches
      différentes, une même philosophie. Le tag <strong>viande française</strong
      > sélectionne uniquement des recettes valorisant notre bœuf élevé en plein air.
      Le tag <strong>healthy</strong> identifie les plats pensés pour l'équilibre
      nutritionnel sans sacrifier le goût.
    </p>
    <p style="color: var(--color-muted); line-height: 1.65;">
      Chaque tag est un fil rouge dans notre cuisine. Les chiffres entre
      parenthèses indiquent le nombre de recettes associées — plus le chiffre
      est élevé, plus le thème est central dans notre approche culinaire. Les
      tags sont particulièrement utiles lorsque vous cuisinez avec une
      contrainte précise : un régime végétalien, une recherche de plats
      équilibrés, ou l'envie de voyager à travers les cuisines du monde sans
      quitter votre cuisine.
    </p>
  </div>

  <FaqSection items={faq} />
</BaseLayout>
