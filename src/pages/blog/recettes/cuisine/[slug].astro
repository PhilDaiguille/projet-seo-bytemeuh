---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { normalizeCuisine } from "../../../../utils/seo";

export async function getStaticPaths() {
  const recettes = await getCollection("recettes");
  const cuisines = [
    ...new Set(recettes.map((r) => r.data.cuisine).filter(Boolean)),
  ];

  const paths: {
    params: { slug: string };
    props: { cuisineName: string; redirectTo?: string };
  }[] = [];

  for (const cuisine of cuisines) {
    const normalizedSlug = normalizeCuisine(cuisine!);
    // Chemin canonique normalisé (sans accents)
    paths.push({
      params: { slug: normalizedSlug },
      props: { cuisineName: cuisine! },
    });
    // Pas d'alias : les redirections d'URL accentuées sont gérées par Vercel (vercel.json)
  }

  return paths;
}

const { slug } = Astro.params;
const { cuisineName, redirectTo } = Astro.props;

// Redirection 301 pour les slugs accentués vers leur équivalent normalisé
if (redirectTo) {
  return Astro.redirect(`/blog/recettes/cuisine/${redirectTo}/`, 301);
}

const recettes = await getCollection("recettes");
const filtered = recettes
  .filter((r) => normalizeCuisine(r.data.cuisine ?? "") === slug)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

if (filtered.length === 0) {
  return Astro.redirect("/blog/recettes/");
}

const SITE_URL = "https://bytemeuh.phildaiguille.fr";
const pageUrl = `${SITE_URL}/blog/recettes/cuisine/${slug}/`;

const cuisineData: Record<
  string,
  { title: string; intro: string; tips: string[]; editorial?: string }
> = {
  indienne: {
    title: "Cuisine indienne",
    intro:
      "La cuisine indienne est l'une des plus riches et diversifiées au monde, forte de millénaires de traditions culinaires. Des plaines du Punjab aux côtes du Kerala, chaque région possède ses propres codes : épices torréfiées, cuisson lente, équilibre subtil entre chaleur, douceur et acidité. Chez Bytemeuh, nous nous inspirons de ces traditions pour des recettes accessibles, savoureuses et ancrées dans le respect des produits.",
    editorial: `
      <h2>La cuisine indienne : bien plus que du curry</h2>
      <p>Quand on évoque la cuisine indienne, le mot « curry » vient immédiatement à l'esprit — mais c'est réduire à une seule note une symphonie d'une incroyable complexité. En réalité, la cuisine indienne regroupe des dizaines de traditions régionales aussi distinctes que la cuisine provençale l'est de la cuisine alsacienne.</p>
      <p>Au nord, dans les États du Punjab et de l'Uttar Pradesh, règnent les <strong>dal makhani</strong> (lentilles beurrées), les <strong>rotis</strong> cuits au tandoor et les currys crémeux enrichis de ghee. Le beurre clarifié — le ghee — est ici un ingrédient central, porteur de saveurs profondes et d'une grande richesse aromatique.</p>
      <p>Au sud, le registre change radicalement. Le riz remplace le pain, le lait de coco fait son apparition en force, et les currys se font plus liquides, plus acides, parfumés au tamarin et aux feuilles de curry fraîches. La cuisine du Kerala, en particulier, est reconnue mondialement pour ses poissons marinés aux épices et ses <strong>appam</strong> (crêpes de riz fermentées) servis avec du lait de coco chaud.</p>

      <h2>Les épices : l'âme de la cuisine indienne</h2>
      <p>La maîtrise des épices est au cœur de chaque recette indienne. Contrairement aux idées reçues, la cuisine indienne n'est pas systématiquement très piquante — elle est avant tout <strong>aromatique</strong>. Le cumin, la coriandre, le curcuma, la cardamome, le fenouil et le fenugrec composent la base de la plupart des mélanges. Le piment, lui, est dosé selon les régions et les goûts.</p>
      <p>La technique de <strong>torréfaction à sec</strong> est fondamentale : faire chauffer les épices entières dans une poêle sans matière grasse libère des huiles essentielles qui décuplent leur puissance aromatique. C'est cette étape que beaucoup négligent à tort dans les recettes occidentalisées.</p>
      <p>Le <strong>garam masala</strong> — littéralement « mélange d'épices chaudes » — est un autre pilier. Chaque famille, chaque région, chaque cuisinier possède sa propre recette. Poivre noir, clous de girofle, cannelle, cardamome verte et muscade en constituent le fond commun, mais les proportions varient infiniment.</p>

      <h2>Les ingrédients phares à avoir dans sa cuisine</h2>
      <p>Pour cuisiner indien à la maison, quelques ingrédients clés font toute la différence :</p>
      <ul>
        <li><strong>Le ghee (beurre clarifié)</strong> : supporte de hautes températures, donne une saveur incomparable aux currys et aux pains.</li>
        <li><strong>Le lait de coco</strong> : indispensable pour les currys du sud. Choisissez une version entière pour un résultat crémeux et équilibré.</li>
        <li><strong>Les lentilles corail</strong> : base du dal, elles cuisent rapidement et absorbent parfaitement les épices.</li>
        <li><strong>Le yaourt entier</strong> : utilisé en marinade (notamment pour le poulet tandoori) et pour adoucir les sauces.</li>
        <li><strong>La pâte de gingembre-ail</strong> : presque systématiquement présente en début de cuisson, elle constitue la base aromatique de la majorité des plats.</li>
      </ul>

      <h2>Les recettes indiennes chez Bytemeuh</h2>
      <p>Nos recettes de cuisine indienne cherchent à respecter l'authenticité des techniques tout en utilisant des produits disponibles en France. Nous travaillons principalement autour des <strong>currys de légumes de saison</strong>, des <strong>dal épicés</strong> et des plats végans — une tradition profondément ancrée dans la culture indienne, notamment dans les communautés jaïnes et végétariennes du Gujarat.</p>
      <p>Chaque recette est pensée pour être reproductible à la maison, sans équipement spécial, avec un niveau d'explication adapté aussi bien aux débutants qu'aux cuisiniers expérimentés. L'objectif : que vous sentiez en cuisine cette même curiosité et ce même respect du produit qui animent la gastronomie indienne depuis des millénaires.</p>
    `,
    tips: [
      "Torréfiez toujours vos épices entières à sec avant de les moudre — c'est la clé de la profondeur aromatique",
      "Le lait de coco entier se remplace par du yaourt entier pour une version plus légère et plus acidulée",
      "Ajoutez les légumes par ordre de dureté : d'abord les racines, puis les cucurbitacées, et les feuilles en tout dernier",
      "Une pincée de sucre de palme en fin de cuisson équilibre l'acidité de la tomate dans les currys",
    ],
  },
  mexicaine: {
    title: "Cuisine mexicaine",
    intro:
      "La cuisine mexicaine, patrimoine de l'UNESCO, marie le maïs, le piment et le cacao dans des créations audacieuses. Les tacos de bœuf incarnent cette tradition avec une viande marinée aux épices chaudes, servie dans des tortillas de maïs artisanales. Le cumin et le paprika créent la base aromatique, l'avocat apporte la fraîcheur crémeuse.",
    editorial: `
      <h2>La cuisine mexicaine : bien plus que des tacos</h2>
      <p>La gastronomie mexicaine est l'une des rares cuisines au monde à avoir été inscrite au patrimoine immatériel de l'UNESCO. Et pour cause : elle est le fruit d'une synthèse unique entre les civilisations mésoaméricaines — aztèque, maya, zapotèque — et les influences espagnoles, africaines et caribéennes apportées par la colonisation. Cette rencontre a donné naissance à une cuisine d'une richesse extraordinaire.</p>
      <p>Le <strong>maïs</strong> est au cœur de tout. La nixtamalisation — ce procédé ancestral qui consiste à tremper les grains dans une eau alcaline (eau de chaux) avant de les moudre — transforme le maïs en masa, la pâte qui donne les tortillas, les tamales et les memelas. Ce procédé, développé il y a plus de 3 000 ans, améliore non seulement la texture et le goût, mais aussi la digestibilité et le profil nutritionnel du maïs.</p>

      <h2>Les piments : une palette de saveurs, pas juste du piquant</h2>
      <p>La cuisine mexicaine recense plus de 64 variétés de piments utilisées en cuisine, chacune avec son profil aromatique propre. Le <strong>ancho</strong> (piment poblano séché) offre des notes de chocolat et de tabac. Le <strong>mulato</strong> apporte une saveur proche du café. Le <strong>chipotle</strong> (jalapeño fumé) donne ce goût fumé caractéristique des adobos. Le <strong>pasilla</strong> ajoute des arômes de prune et de cerise noire.</p>
      <p>Comprendre les piments mexicains, c'est comprendre que le piquant n'est qu'une dimension parmi d'autres. Un bon <em>mole negro</em> d'Oaxaca peut comporter jusqu'à 30 ingrédients différents dont plusieurs variétés de piments, du chocolat noir, des épices, des noix et du pain toasté — le tout cuit pendant des heures dans un équilibre parfait entre amertume, sucré, piquant et umami.</p>

      <h2>La sainte trinité mexicaine : maïs, haricots, courge</h2>
      <p>La <em>milpa</em> — ce système agricole ancestral qui associe maïs, haricots et courge — est bien plus qu'une technique agricole : c'est le fondement de la gastronomie mexicaine. Ces trois cultures se complètent parfaitement sur le plan nutritionnel (les haricots compensent l'absence de certains acides aminés dans le maïs) et culinaire.</p>
      <p>Les <strong>frijoles</strong> (haricots) se déclinent en dizaines de variétés — noirs, pinto, ayocote, bayo — chacun avec un goût et une texture distincts. Les <strong>calabacitas</strong> (courges d'été) entrent dans les sauces, les ragoûts et les salades. Et le maïs, sous toutes ses formes, est l'accompagnement universel.</p>

      <h2>Les recettes mexicaines chez Bytemeuh</h2>
      <p>Nos recettes s'inspirent de la tradition mexicaine authentique tout en utilisant des produits disponibles en France. Nous travaillons autour des tacos — tortillas de maïs artisanales, viandes marinées aux épices, salsas fraîches — mais aussi des plats plus longs comme les <strong>enchiladas</strong> au mole ou les <strong>tamales</strong> vapeur. L'objectif est toujours de respecter l'esprit d'une cuisine généreuse, épicée avec subtilité, et profondément ancrée dans la culture du partage.</p>
    `,
    tips: [
      "Marinez la viande au minimum 2h pour que les épices pénètrent",
      "Torréfiez les tortillas directement sur la flamme pour un goût fumé",
      "L'avocat doit être bien mûr — il doit céder légèrement sous la pression",
      "Pour une salsa fraîche : pas de mixeur, hachez tout au couteau pour la texture",
    ],
  },
  chinoise: {
    title: "Cuisine chinoise",
    intro:
      "La cuisine chinoise révolutionne le rapport à la viande avec des techniques de wok ancestrales. Les ravioli chinois (jiaozi) symbolisent la cuisine du Nord : pâte fine emprisonnant une farce parfumée au bœuf, gingembre frais et sauce soja. La sauce huître crée un équilibre salé-umami caractéristique.",
    editorial: `
      <h2>La cuisine chinoise : huit grandes traditions régionales</h2>
      <p>Réduire la cuisine chinoise à quelques plats standardisés serait ignorer l'une des traditions culinaires les plus vastes et les plus complexes du monde. La Chine compte officiellement <strong>huit grandes écoles culinaires régionales</strong>, chacune avec ses ingrédients, techniques et philosophies distinctes : Cantonaise (Guangdong), Sichuanaise, Shanghaiaise, Fujianaise, Zhejiangaise, Hunanese, Anhui et Shandong.</p>
      <p>La cuisine <strong>cantonaise</strong>, la plus connue en Occident, privilégie la fraîcheur des ingrédients et des cuissons brèves. Le dim sum — ces petites bouchées servies avec du thé lors du <em>yum cha</em> — en est l'expression la plus célèbre : har gow (ravioli aux crevettes), siu mai (boulettes de porc), char siu bao (brioches au porc laqué).</p>
      <p>La cuisine du <strong>Sichuan</strong>, elle, est à l'opposé : explosif, complexe, numbing. Le poivre de Sichuan crée une sensation de picotement anesthésiante (<em>má</em>) qui interagit avec la chaleur des piments (<em>là</em>) pour créer le caractéristique <em>málà</em>. Un mapo tofu bien fait est une expérience sensorielle totale.</p>

      <h2>Le wok : outil et philosophie</h2>
      <p>Le wok n'est pas qu'une poêle ronde — c'est un outil de cuisson qui exige une maîtrise du feu. La notion de <strong>"wok hei"</strong> (breath of the wok) désigne ce goût fumé, légèrement carbonisé, qu'une cuisson à très haute température sur feu vif confère aux aliments. C'est ce qui distingue un sauté fait maison d'un plat de restaurant cantonais : la flamme brûlante, les ingrédients qui dansent, la Maillard qui s'enchaîne en secondes.</p>
      <p>Pour reproduire le wok hei à la maison, la clé est de ne jamais surcharger le wok. Cuisinez par petites quantités, feu au maximum, et manipulez rapidement. Un wok en acier au carbone (pas antiadhésif) bien culotté est l'investissement le plus rentable pour la cuisine asiatique.</p>

      <h2>Les jiaozi : l'art des ravioli chinois</h2>
      <p>Les jiaozi (ravioli) sont bien plus qu'un plat — ils sont un rituel. En Chine du Nord, toute la famille se retrouve pour plier les jiaozi ensemble avant le Nouvel An. Chaque famille a sa technique de pliage, sa recette de farce, ses secrets transmis de génération en génération.</p>
      <p>La pâte à jiaozi est différente de la pâte à pasta : moins d'œufs, plus d'eau bouillante, texture plus élastique et moins fragile. La farce classique est un mélange de porc haché, chou chinois, gingembre et ciboule, mais les variantes régionales sont infinies : crevettes+porc, agneau+oignon, tofu+champignons.</p>

      <h2>Les recettes chinoises chez Bytemeuh</h2>
      <p>Nous explorons la cuisine chinoise à travers ses techniques fondamentales : la cuisson au wok, la vapeur douce, et les marinades umami. Nos recettes privilégient des ingrédients disponibles en France — sauce soja de qualité, gingembre frais, vinaigre de riz, huile de sésame grillé — pour reproduire des plats authentiques sans compromis. Des jiaozi maison aux sautés de légumes au wok hei, chaque recette est une invitation à maîtriser ces techniques ancestrales.</p>
    `,
    tips: [
      "La pâte à ravioli se travaille froide — réfrigérez 30min avant",
      "Ne surchargez pas les ravioli : 1 cuillère à café de farce max",
      "Faites blanchir les ravioli 1min de moins que recommandé — ils finissent dans le wok",
      "Le wok doit être fumant avant d'ajouter quoi que ce soit — chauffez à vide 3 min",
    ],
  },
  mediterraneenne: {
    title: "Cuisine méditerranéenne",
    intro:
      "La cuisine méditerranéenne célèbre les produits de la terre : huile d'olive, légumes grillés, herbes fraîches. Le kebab de bœuf et la salade de quinoa illustrent cette tradition avec des recettes parfumées au paprika et au cumin, où les légumes frais équilibrent la richesse de la viande.",
    editorial: `
      <h2>La cuisine méditerranéenne : un art de vivre avant tout</h2>
      <p>Le régime méditerranéen — inscrit au patrimoine culturel immatériel de l'UNESCO — n'est pas un régime au sens diététique du terme. C'est un <strong>art de vivre</strong> partagé par les peuples du pourtour méditerranéen : Grecs, Italiens du Sud, Espagnols, Marocains, Libanais, Tunisiens. Un mode de vie où le repas est un rituel social, où les ingrédients de saison dictent le menu, et où l'huile d'olive est le fil conducteur.</p>
      <p>Ce qui unit ces cuisines si différentes ? La <strong>triade méditerranéenne</strong> : blé (pain, pâtes, couscous), huile d'olive et vin. Autour de cette triade : des légumes grillés, des légumineuses, du poisson frais, des herbes aromatiques en quantité. Les protéines animales — surtout la viande rouge — sont présentes mais en moindre proportion qu'en Europe du Nord.</p>

      <h2>L'huile d'olive : l'or liquide du bassin méditerranéen</h2>
      <p>L'huile d'olive n'est pas un simple corps gras — c'est un ingrédient à part entière avec ses arômes, ses amertumes, sa fraîcheur. Une huile d'olive extra vierge de qualité présente des notes herbacées, fruitées, parfois poivrées. Elle doit piquer légèrement en gorge — signe de sa richesse en polyphénols antioxydants.</p>
      <p>La règle d'or : utilisez <strong>deux huiles d'olive différentes</strong>. Une huile de qualité standard pour la cuisson (les arômes partent à la chaleur), et une huile d'olive extra vierge de qualité pour la finition et les vinaigrettes. Elles ne se substituent pas.</p>

      <h2>Les herbes fraîches : l'identité aromatique de chaque cuisine</h2>
      <p>Si l'huile d'olive unit les cuisines méditerranéennes, les herbes les distinguent. Le <strong>basilic</strong> est l'âme de la cuisine ligurienne. Le <strong>thym et le romarin</strong> définissent la Provence. La <strong>menthe fraîche</strong> parfume les mezzés libanais. La <strong>coriandre</strong> est omniprésente au Maroc. Le <strong>persil plat</strong> finit presque tous les plats grecs.</p>
      <p>Toutes ces herbes partagent une caractéristique : elles se révèlent à l'état frais, pas séché. Elles s'ajoutent en fin de cuisson ou à cru — jamais au début — pour préserver leurs huiles essentielles et leur fraîcheur aromatique.</p>

      <h2>Les recettes méditerranéennes chez Bytemeuh</h2>
      <p>Notre approche de la cuisine méditerranéenne est celle du respect du produit et de la saison. Nos recettes célèbrent les légumes d'été (aubergines, poivrons, tomates, courgettes) mais aussi les légumineuses — pois chiches, lentilles, fèves — qui constituent le cœur protéique de ces cuisines. Du houmous maison au kebab grillé aux herbes, en passant par les salades composées généreuses, chaque recette est pensée pour mettre en valeur la qualité des ingrédients.</p>
    `,
    tips: [
      "L'huile d'olive s'utilise à température ambiante pour préserver ses saveurs",
      "Grillez les légumes jusqu'à obtenir des marques profondes — c'est là que le goût se crée",
      "Le quinoa se rince toujours avant cuisson pour éliminer l'amertume",
      "Les herbes fraîches s'ajoutent en toute fin — la chaleur détruit leurs arômes en secondes",
    ],
  },
  francaise: {
    title: "Cuisine française",
    intro:
      "La cuisine française, pilier de la gastronomie mondiale, repose sur le respect des produits et des techniques classiques. La ratatouille provençale incarne cette philosophie : un mijotage lent où aubergines, courgettes et poivrons libèrent leurs sucs. Le thym et le laurier ancrent les saveurs, le basilic frais illumine le plat à la toute fin.",
    editorial: `
      <h2>La cuisine française : une technique au service du produit</h2>
      <p>La cuisine française est souvent décrite comme la mère de toutes les cuisines occidentales. Ses sauces — béchamel, velouté, espagnole, hollandaise, tomat — constituent les <strong>cinq sauces mères</strong> qui ont formé des générations de cuisiniers à travers le monde. Mais la vraie force de la cuisine française n'est pas dans ses sauces : c'est dans sa philosophie.</p>
      <p>Cette philosophie tient en une phrase : <em>le produit prime sur la technique</em>. Un grand cuisinier français cherche d'abord le meilleur légume de saison, la meilleure viande de terroir, le meilleur fromage d'affineur — et la technique sert à révéler ces qualités, jamais à les masquer. C'est l'opposé de la cuisine spectacle : ici, l'humilité culinaire est une vertu.</p>

      <h2>Le terroir : concept central de la gastronomie française</h2>
      <p>Le concept de <strong>terroir</strong> — ce lien indissociable entre un produit, sa géographie, son sol et son climat — est profondément français. Il s'applique d'abord au vin (les AOC), mais il structure toute la pensée gastronomique française. Une volaille de Bresse n'a pas le même goût qu'une volaille industrielle — pas parce que l'une est meilleure que l'autre en théorie, mais parce que son sol, son alimentation, son stress ou son absence définissent sa chair.</p>
      <p>Ce rapport au terroir explique pourquoi la cuisine française est fondamentalement <strong>saisonnière</strong>. Les asperges de mai, les cerises de juin, les champignons d'automne, la truffe d'hiver : chaque saison apporte ses ingrédients phares, et la cuisine s'adapte. Un chef français qui propose des fraises en décembre est perçu comme quelqu'un qui a perdu le sens du produit.</p>

      <h2>Les grandes techniques françaises à maîtriser</h2>
      <p>Derrière les plats iconiques de la cuisine française se cachent quelques techniques fondamentales :</p>
      <ul>
        <li><strong>La brunoise et la julienne</strong> : couper régulièrement pour une cuisson homogène. La précision du couteau n'est pas une question d'esthétique — c'est une question de cuisson parfaite.</li>
        <li><strong>Le rissolage</strong> : faire revenir dans un peu de matière grasse pour créer une croûte dorée (réaction de Maillard) qui concentre les saveurs avant de mouiller ou de mijoter.</li>
        <li><strong>Le déglaçage</strong> : récupérer les sucs de cuisson avec un liquide (vin, bouillon) pour créer un fond de sauce concentré et plein de goût.</li>
        <li><strong>Le confit</strong> : cuisson lente dans la graisse à basse température. Le canard confit, les tomates confites, l'ail confit — tous révèlent une douceur et une richesse impossibles à obtenir autrement.</li>
      </ul>

      <h2>Les recettes françaises chez Bytemeuh</h2>
      <p>Nos recettes françaises célèbrent le produit de terroir et les techniques classiques réinterprétées pour le quotidien. La ratatouille provençale, les légumes farcis, les gratins de légumes d'été : autant de plats qui tirent le meilleur des produits Bytemeuh dans le respect des saisons. L'objectif n'est jamais la complexité pour la complexité — c'est la justesse d'une cuisine qui sait quand s'effacer pour laisser parler l'ingrédient.</p>
    `,
    tips: [
      "Faites dégorger les aubergines avec du sel 30min avant cuisson",
      "Chaque légume doit être sauté séparément pour garder sa texture",
      "La ratatouille est meilleure le lendemain — les saveurs se développent au repos",
      "Déglacez toujours avec un peu de vin ou de bouillon pour récupérer les sucs",
    ],
  },
  americaine: {
    title: "Cuisine américaine",
    intro:
      'La cuisine américaine a évolué du hamburger de rue à une gastronomie raffinée. Le burger de bœuf maison illustre cette transformation : galette de bœuf 15% MG, cheddar fondant, légumes croquants. Une révolution "gourmet" qui revendique la qualité des ingrédients et le savoir-faire français.',
    editorial: `
      <h2>La cuisine américaine : un melting-pot gastronomique</h2>
      <p>La cuisine américaine est souvent réduite à ses stéréotypes — burgers, hot-dogs, mac & cheese. Mais cette vision passe à côté d'une réalité bien plus riche : la cuisine américaine est peut-être la <strong>plus grande fusion culinaire de l'histoire humaine</strong>, née de l'immigration de dizaines de cultures sur un continent immense aux terroirs variés.</p>
      <p>Le barbecue du Texas n'a rien à voir avec celui de la Caroline du Nord ou de Kansas City — chacun revendique sa tradition, ses bois de fumée, ses temps de cuisson, ses sauces (ou leur absence). La cuisine cajun de Louisiane mêle influences françaises, africaines et amérindiennes dans des plats uniques. La cuisine new-yorkaise est une superposition de vagues d'immigration : italienne, juive, chinoise, portoricaine, coréenne.</p>

      <h2>Le burger : de la street food à la haute gastronomie</h2>
      <p>Le hamburger est l'invention culinaire américaine la plus universellement adoptée. Et pourtant, il est souvent mal compris — réduit à une galette industrielle entre deux pains mous. Le <strong>burger gourmet</strong> tel qu'on le comprend chez Bytemeuh, c'est tout autre chose.</p>
      <p>La galette d'abord : un mélange de bœuf haché à 15-20% de matière grasse, jamais compressé, légèrement assaisonné (sel, poivre, rien d'autre). Le bœuf parle pour lui-même. La cuisson : feu très vif, fonte ou acier carbone, 3-4 minutes par face. Un seul retournement. Le fromage s'ajoute en toute fin, quand la galette est retirée du feu, pour fondre doucement sans brûler.</p>
      <p>Le pain : brioché ou légèrement toasté, il doit tenir la garniture sans se désintégrer. La garniture : tomates fraîches, laitue croquante, pickles maison pour l'acidité, oignons caramélisés pour la douceur, sauce maison. Chaque élément a un rôle précis dans l'équilibre du burger.</p>

      <h2>Le BBQ : une tradition de cuisson au long cours</h2>
      <p>Le barbecue américain est une philosophie de cuisson — pas juste une méthode. Il repose sur deux principes : <strong>low and slow</strong> (basse température, longue durée) et la fumée comme ingrédient à part entière. Des poitrines de bœuf fumées pendant 12 heures dans un fumoir à hickory, des côtes de porc au bois de cerisier, des poulets au mesquite : chaque bois apporte ses arômes spécifiques.</p>
      <p>Cette tradition, née dans le sud des États-Unis, est profondément ancrée dans la culture afro-américaine. Les esclaves étaient chargés de surveiller les pits (fosses de cuisson) pendant des heures — et ils ont développé, au fil des générations, une maîtrise extraordinaire de la cuisson basse température. Un hommage essentiel à rendre quand on parle de barbecue américain.</p>

      <h2>Les recettes américaines chez Bytemeuh</h2>
      <p>Nous explorons la cuisine américaine à travers ses plats les plus emblématiques, revisités avec des produits Bytemeuh de qualité. Le burger gourmet est notre signature : bœuf français tracé, pain brioché artisanal, condiments maison. Mais nous explorons aussi les ailes de poulet marinées, les corn dogs végans et les coleslaw fermentées — autant d'expressions d'une cuisine généreuse qui sait se réinventer sans perdre son âme.</p>
