---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { normalizeCuisine } from "../../../../utils/seo";

export async function getStaticPaths() {
  const recettes = await getCollection("recettes");
  const cuisines = [
    ...new Set(recettes.map((r) => r.data.cuisine).filter(Boolean)),
  ];

  const paths: { params: { slug: string }; props: { cuisineName: string; redirectTo?: string } }[] = [];

  for (const cuisine of cuisines) {
    const normalizedSlug = normalizeCuisine(cuisine!);
    // Chemin canonique normalisé (sans accents)
    paths.push({
      params: { slug: normalizedSlug },
      props: { cuisineName: cuisine! },
    });
    // Alias avec le nom brut en minuscules si différent (ex: "française" -> redirige vers "francaise")
    const rawSlug = cuisine!
      .toLowerCase()
      .replace(/^cuisine\s+/i, "")
      .replace(/\s+/g, "-")
      .replace(/[^\w\u00C0-\u024F-]/g, "");
    if (rawSlug !== normalizedSlug) {
      paths.push({
        params: { slug: rawSlug },
        props: { cuisineName: cuisine!, redirectTo: normalizedSlug },
      });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const { cuisineName, redirectTo } = Astro.props;

// Redirection 301 pour les slugs accentués vers leur équivalent normalisé
if (redirectTo) {
  return Astro.redirect(`/blog/recettes/cuisine/${redirectTo}/`, 301);
}

const recettes = await getCollection("recettes");
const filtered = recettes
  .filter((r) => normalizeCuisine(r.data.cuisine ?? "") === slug)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

if (filtered.length === 0) {
  return Astro.redirect("/blog/recettes/");
}

const SITE_URL = "https://bytemeuh.phildaiguille.fr";
const pageUrl = `${SITE_URL}/blog/recettes/cuisine/${slug}/`;

const cuisineData: Record<
  string,
  { title: string; intro: string; tips: string[]; editorial?: string }
> = {
  indienne: {
    title: "Cuisine indienne",
    intro:
      "La cuisine indienne est l'une des plus riches et diversifiées au monde, forte de millénaires de traditions culinaires. Des plaines du Punjab aux côtes du Kerala, chaque région possède ses propres codes : épices torréfiées, cuisson lente, équilibre subtil entre chaleur, douceur et acidité. Chez Bytemeuh, nous nous inspirons de ces traditions pour des recettes accessibles, savoureuses et ancrées dans le respect des produits.",
    editorial: `
      <h2>La cuisine indienne : bien plus que du curry</h2>
      <p>Quand on évoque la cuisine indienne, le mot « curry » vient immédiatement à l'esprit — mais c'est réduire à une seule note une symphonie d'une incroyable complexité. En réalité, la cuisine indienne regroupe des dizaines de traditions régionales aussi distinctes que la cuisine provençale l'est de la cuisine alsacienne.</p>
      <p>Au nord, dans les États du Punjab et de l'Uttar Pradesh, règnent les <strong>dal makhani</strong> (lentilles beurrées), les <strong>rotis</strong> cuits au tandoor et les currys crémeux enrichis de ghee. Le beurre clarifié — le ghee — est ici un ingrédient central, porteur de saveurs profondes et d'une grande richesse aromatique.</p>
      <p>Au sud, le registre change radicalement. Le riz remplace le pain, le lait de coco fait son apparition en force, et les currys se font plus liquides, plus acides, parfumés au tamarin et aux feuilles de curry fraîches. La cuisine du Kerala, en particulier, est reconnue mondialement pour ses poissons marinés aux épices et ses <strong>appam</strong> (crêpes de riz fermentées) servis avec du lait de coco chaud.</p>

      <h2>Les épices : l'âme de la cuisine indienne</h2>
      <p>La maîtrise des épices est au cœur de chaque recette indienne. Contrairement aux idées reçues, la cuisine indienne n'est pas systématiquement très piquante — elle est avant tout <strong>aromatique</strong>. Le cumin, la coriandre, le curcuma, la cardamome, le fenouil et le fenugrec composent la base de la plupart des mélanges. Le piment, lui, est dosé selon les régions et les goûts.</p>
      <p>La technique de <strong>torréfaction à sec</strong> est fondamentale : faire chauffer les épices entières dans une poêle sans matière grasse libère des huiles essentielles qui décuplent leur puissance aromatique. C'est cette étape que beaucoup négligent à tort dans les recettes occidentalisées.</p>
      <p>Le <strong>garam masala</strong> — littéralement « mélange d'épices chaudes » — est un autre pilier. Chaque famille, chaque région, chaque cuisinier possède sa propre recette. Poivre noir, clous de girofle, cannelle, cardamome verte et muscade en constituent le fond commun, mais les proportions varient infiniment.</p>

      <h2>Les ingrédients phares à avoir dans sa cuisine</h2>
      <p>Pour cuisiner indien à la maison, quelques ingrédients clés font toute la différence :</p>
      <ul>
        <li><strong>Le ghee (beurre clarifié)</strong> : supporte de hautes températures, donne une saveur incomparable aux currys et aux pains.</li>
        <li><strong>Le lait de coco</strong> : indispensable pour les currys du sud. Choisissez une version entière pour un résultat crémeux et équilibré.</li>
        <li><strong>Les lentilles corail</strong> : base du dal, elles cuisent rapidement et absorbent parfaitement les épices.</li>
        <li><strong>Le yaourt entier</strong> : utilisé en marinade (notamment pour le poulet tandoori) et pour adoucir les sauces.</li>
        <li><strong>La pâte de gingembre-ail</strong> : presque systématiquement présente en début de cuisson, elle constitue la base aromatique de la majorité des plats.</li>
      </ul>

      <h2>Les recettes indiennes chez Bytemeuh</h2>
      <p>Nos recettes de cuisine indienne cherchent à respecter l'authenticité des techniques tout en utilisant des produits disponibles en France. Nous travaillons principalement autour des <strong>currys de légumes de saison</strong>, des <strong>dal épicés</strong> et des plats végans — une tradition profondément ancrée dans la culture indienne, notamment dans les communautés jaïnes et végétariennes du Gujarat.</p>
      <p>Chaque recette est pensée pour être reproductible à la maison, sans équipement spécial, avec un niveau d'explication adapté aussi bien aux débutants qu'aux cuisiniers expérimentés. L'objectif : que vous sentiez en cuisine cette même curiosité et ce même respect du produit qui animent la gastronomie indienne depuis des millénaires.</p>
    `,
    tips: [
      "Torréfiez toujours vos épices entières à sec avant de les moudre — c'est la clé de la profondeur aromatique",
      "Le lait de coco entier se remplace par du yaourt entier pour une version plus légère et plus acidulée",
      "Ajoutez les légumes par ordre de dureté : d'abord les racines, puis les cucurbitacées, et les feuilles en tout dernier",
      "Une pincée de sucre de palme en fin de cuisson équilibre l'acidité de la tomate dans les currys",
    ],
  },
  mexicaine: {
    title: "Cuisine mexicaine",
    intro:
      "La cuisine mexicaine, patrimoine de l'UNESCO, marie le maïs, le piment et le cacao dans des créations audacieuses. Les tacos de bœuf incarnent cette tradition avec une viande marinée aux épices chaudes, servie dans des tortillas de maïs artisanales. Le cumin et le paprika créent la base aromatique, l'avocat apporte la fraîcheur crémeuse.",
    tips: [
      "Marinez la viande au minimum 2h pour que les épices pénètrent",
      "Torréfiez les tortillas directement sur la flamme pour un goût fumé",
      "L'avocat doit être bien mûr — il doit céder légèrement sous la pression",
    ],
  },
  chinoise: {
    title: "Cuisine chinoise",
    intro:
      "La cuisine chinoise révolutionne le rapport à la viande avec des techniques de wok ancestrales. Les ravioli chinois (jiaozi) symbolisent la cuisine du Nord : pâte fine emprisonnant une farce parfumée au bœuf, gingembre frais et sauce soja. La sauce huître crée un équilibre salé-umami caractéristique.",
    tips: [
      "La pâte à ravioli se travaille froide — réfrigérez 30min avant",
      "Ne surchargez pas les ravioli : 1 cuillère à café de farce max",
      "Faites blanchir les ravioli 1min de moins que recommandé — ils finissent dans le wok",
    ],
  },
  mediterraneenne: {
    title: "Cuisine méditerranéenne",
    intro:
      "La cuisine méditerranéenne célèbre les produits de la terre : huile d'olive, légumes grillés, herbes fraîches. Le kebab de bœuf et la salade de quinoa illustrent cette tradition avec des recettes parfumées au paprika et au cumin, où les légumes frais équilibrent la richesse de la viande.",
    tips: [
      "L'huile d'olive s'utilise à température ambiante pour préserver ses saveurs",
      "Grillez les légumes jusqu'à obtenir des marques profondes",
      "Le quinoa se rince toujours avant cuisson pour éliminer l'amertume",
    ],
  },
  francaise: {
    title: "Cuisine française",
    intro:
      "La cuisine française, pilier de la gastronomie mondiale, repose sur le respect des produits et des techniques classiques. La ratatouille provençale incarne cette philosophie : un mijotage lent où aubergines, courgettes et poivrons libèrent leurs sucs. Le thym et le laurier ancrent les saveurs, le basilic frais illumine le plat à la toute fin.",
    tips: [
      "Faites dégorger les aubergines avec du sel 30min avant cuisson",
      "Chaque légume doit être sauté séparément pour garder sa texture",
      "La ratatouille est meilleure le lendemain — les saveurs se développent",
    ],
  },
  americaine: {
    title: "Cuisine américaine",
    intro:
      'La cuisine américaine a évolué du hamburger de rue à une gastronomie raffinée. Le burger de bœuf maison illustre cette transformation : galette de bœuf 15% MG, cheddar fondant, légumes croquants. Une révolution "gourmet" qui revendique la qualité des ingrédients et le savoir-faire français.',
    tips: [
      "Formez les galettes plus larges que le pain — elles rétrécissent à la cuisson",
      "Créez un creux au centre avec le pouce pour éviter le bombage",
      "Ne retournez qu'une fois : 3-4 min par face à feu vif",
    ],
  },
  "moyen-orientale": {
    title: "Cuisine moyen-orientale",
    intro:
      "La cuisine moyen-orientale unit les saveurs de la Perse à la Méditerranée dans des plats généreux. Le shakshuka, roi des petits-déjeuners, pochée les œufs dans une sauce tomate épicée aux poivrons et cumin. Le pain pita permet de saucer sans manières — un plat de secours pour@faim qui traverse les frontières.",
    tips: [
      "La sauce doit être bien réduite avant d'y casser les œufs",
      "Couvrez pendant la cuisson pour que les blancs prennent sans que les jaunes durcissent",
      "Servez avec du persil frais et un filet d'huile d'olive",
    ],
  },
  "fusion-franco-italienne": {
    title: "Cuisine fusion franco-italienne",
    intro:
      "La fusion franco-italienne naît de la rencontre entre deux grandes traditions culinaires européennes : la rigueur technique française — ses sauces, ses pâtes levées, son goût pour les produits du terroir — et la générosité méditerranéenne italienne, ses herbes fraîches, ses fromages affinés, son huile d'olive. Chez Bytemeuh, nous explorons ce dialogue entre les deux cultures à travers des recettes qui rendent hommage aux deux côtés des Alpes.",
    editorial: `
      <h2>Quand la France rencontre l'Italie en cuisine</h2>
      <p>Les frontières culinaires entre la France et l'Italie ont toujours été poreuses. Des Alpes à la Méditerranée, les échanges entre les deux cultures gastronomiques remontent à des siècles — des cuisiniers florentins amenés à la cour de France par Catherine de Médicis aux influences niçoises et provençales qui s'entremêlent à chaque repas de bord de mer. La cuisine fusion franco-italienne ne cherche pas à fusionner pour le plaisir de la modernité : elle révèle des affinités profondes et naturelles.</p>
      <p>Ce dialogue culinaire s'exprime à travers des ingrédients partagés — le fromage, les herbes aromatiques, le vin en cuisine, les pâtes et les pâtes levées — mais aussi à travers des techniques complémentaires. La <strong>précision française</strong> de la pâtisserie s'allie à la <strong>spontanéité italienne</strong> de la cuisine du quotidien.</p>

      <h2>Les grands ingrédients de ce mariage culinaire</h2>
      <p>Quelques ingrédients phares incarnent ce dialogue entre les deux traditions :</p>
      <ul>
        <li><strong>Le fromage de chèvre</strong> : très ancré dans la tradition fromagère française (Sainte-Maure, Crottin de Chavignol), il dialogue parfaitement avec les tomates séchées, le basilic et l'huile d'olive italiens.</li>
        <li><strong>La pâte à pizza maison</strong> : la technique française de la <em>pousse lente au réfrigérateur</em> transforme une recette italienne en quelque chose de plus complexe, plus croustillant, plus digeste.</li>
        <li><strong>Le miel du terroir</strong> : utilisé en touche finale sur des bases salées, il crée un contraste sucré-salé qui rappelle les agrodolci italiens mais avec les arômes floraux du miel français.</li>
        <li><strong>Les herbes fraîches</strong> : basilic, thym, romarin — les deux cuisines partagent un même amour des herbes méditerranéennes, utilisées en quantité généreuse et ajoutées à cru pour préserver leur fraîcheur.</li>
        <li><strong>L'huile d'olive extra vierge</strong> : présente dans les deux traditions, elle apporte fruité et longueur en bouche, aussi bien dans les sauces françaises que dans les garnitures italiennes.</li>
      </ul>

      <h2>Les techniques au service du goût</h2>
      <p>La cuisine franco-italienne chez Bytemeuh repose sur quelques principes fondamentaux :</p>
      <p>La <strong>fermentation longue de la pâte</strong> est l'une de nos signatures. Contrairement aux pâtes à pizza préparées dans l'heure, une pâte laissée 24 à 48 heures au réfrigérateur développe une complexité aromatique incomparable, des bulles d'air plus légères et une croûte plus croustillante à la cuisson. C'est la technique des <em>pizzaiolos napolitains</em> réinterprétée avec la patience des boulangers français.</p>
      <p>L'utilisation du <strong>fromage à température ambiante</strong> est un autre point d'attention. Un fromage de chèvre sorti du réfrigérateur une heure avant d'être utilisé fondera plus uniformément, libérera mieux ses arômes et créera cette texture crémeuse caractéristique que l'on cherche dans ce type de recettes.</p>

      <h2>Les recettes fusion franco-italiennes chez Bytemeuh</h2>
      <p>Nos recettes explorent différentes facettes de ce dialogue culinaire. De la <strong>pizza chèvre-miel</strong> — notre recette phare — aux tarts flambées revisitées avec des ingrédients italiens, en passant par des risottos enrichis de techniques françaises de réduction, chaque plat cherche à mettre en valeur le meilleur des deux cultures.</p>
      <p>L'idée n'est jamais la fusion pour la fusion, mais de trouver des associations qui ont du sens : des saveurs complémentaires, des textures qui se répondent, un équilibre entre la richesse française et la légèreté méditerranéenne italienne. Des recettes ancrées dans une vraie tradition, servies avec le goût du partage qui est au cœur de Bytemeuh.</p>
    `,
    tips: [
      "Laissez reposer la pâte 24h au réfrigérateur pour une fermentation lente qui développe les arômes et la légèreté",
      "Le fromage de chèvre doit être sorti 1h avant utilisation pour mieux fondre et libérer ses arômes",
      "Le miel s'ajoute toujours en toute fin de cuisson ou après sortie du four — trop tôt et il caramélise et brûle",
      "Une cuisson à très haute température (250°C ou plus) est la clé d'une pizza croustillante à la base et moelleuse au centre",
    ],
  },
  "fusion-hawaienne-japonaise": {
    title: "Cuisine hawaïenne-japonaise",
    intro:
      "Le poke bowl est né à Hawaï de la rencontre entre pêcheurs japonais et communautés locales. Le tofu ferme absorbe la marinade soja-sésame, le riz sushi collant supporte les toppings fraîcheur : avocat crémeux, mangue sucrée, carotte croquante.",
    tips: [
      "Marinez le tofu minimum 2h pour qu'il goûte vraiment",
      "Le riz doit être tiède — froid il n'absorbe pas la marinade",
      "Ajoutez la sauce sriracha uniquement au moment de servir",
    ],
  },
  "fusion-asiatique-francaise": {
    title: "Cuisine fusion asiatique-française",
    intro:
      "Les bao buns marient la tradition chinoise du baozi à la sensibilité française. Ces petites buns vapotisées emprisonnent une farce de jack-fruit mariné, pickles croquants et coriandre fraîche. Une street food de qualité restaurant.",
    tips: [
      "La pâte doit être parfaitement lisse et reposer 1h à température ambiante",
      "Le bain de vapeur ne doit pas bouillir — vapeur douce uniquement",
      "Garnissez immédiatement après cuisson — les buns ramollissent vite",
    ],
  },
};

const cuisine = cuisineData[slug!] ?? {
  title: cuisineName,
  intro: `Découvrez nos recettes de ${cuisineName.toLowerCase()}. Des plats savoureux préparés avec des produits de ferme Bytemeuh, dans le respect des traditions et des saisons.`,
  tips: [
    "Utilisez des ingrédients de qualité pour des résultats optimaux",
    "Adaptez les quantités selon le nombre de personnes",
    "N'hésitez pas à ajuster les épices selon vos goûts",
  ],
};

const allCuisines = [
  ...new Set(recettes.map((r) => r.data.cuisine).filter(Boolean)),
];

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      name: `Recettes de ${cuisine.title} — Bytemeuh`,
      description: cuisine.intro,
      url: pageUrl,
      mainEntity: {
        "@type": "ItemList",
        itemListElement: filtered.map((r, i) => ({
          "@type": "ListItem",
          position: i + 1,
          url: `${SITE_URL}/blog/recettes/${r.id}/`,
        })),
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: `${SITE_URL}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: `${SITE_URL}/blog/`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: "Recettes",
          item: `${SITE_URL}/blog/recettes/`,
        },
        {
          "@type": "ListItem",
          position: 4,
          name: "Cuisines",
          item: `${SITE_URL}/blog/recettes/cuisine/`,
        },
        {
          "@type": "ListItem",
          position: 5,
          name: cuisine.title,
          item: pageUrl,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={`Recettes de ${cuisine.title}`}
  description={`${filtered.length} recette${filtered.length > 1 ? "s" : ""} de ${cuisine.title.toLowerCase()} à découvrir sur Bytemeuh. ${filtered.map((r) => r.data.title).join(", ")}.`.slice(0, 155)}
  canonical={pageUrl}
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/">Blog</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/recettes/">Recettes</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/recettes/cuisine/">Cuisines</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li aria-current="page">{cuisine.title}</li>
    </ol>
  </nav>

  <header class="pseo-header">
    <span class="pseo-badge">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><circle cx="12" cy="12" r="10"></circle><line
          x1="2"
          y1="12"
          x2="22"
          y2="12"></line><path
          d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
        ></path></svg
      >
      Cuisine
    </span>
    <h1>Recettes de {cuisine.title}</h1>
    <p class="pseo-intro">{cuisine.intro}</p>
  </header>

  <section class="pseo-recipes" aria-label={`Recettes de ${cuisine.title}`}>
    <div class="cards-grid">
      {
        filtered.map((recette) => (
          <article class="card">
            <a
              href={`/blog/recettes/${recette.id}/`}
              aria-label={`Recette : ${recette.data.title}`}
            >
              <div class="card-image">
                {recette.data.featuredImage && (
                  <Image
                    src={recette.data.featuredImage}
                    alt={recette.data.featuredImageAlt ?? recette.data.title}
                    width={400}
                    height={267}
                    loading="lazy"
                    quality={70}
                    decoding="async"
                  />
                )}
                <span class="card-badge badge-recipe">Recette</span>
              </div>
              <div class="card-body">
                <div class="card-meta">
                  {recette.data.totalTime && (
                    <span class="card-meta-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>
                      {recette.data.totalTime
                        .replace("PT", "")
                        .replace("H", " h ")
                        .replace("M", " min")
                        .trim()}
                    </span>
                  )}
                  {recette.data.difficulty && (
                    <span class="card-meta-item">
                      {recette.data.difficulty}
                    </span>
                  )}
                  {recette.data.aggregateRating && (
                    <span class="card-meta-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="#f59e0b"
                        stroke="#f59e0b"
                        stroke-width="1"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                      </svg>
                      {recette.data.aggregateRating.ratingValue}
                    </span>
                  )}
                </div>
                <h2 class="card-title">{recette.data.title}</h2>
                <p class="card-description">{recette.data.description}</p>
              </div>
              {recette.data.tags && recette.data.tags.length > 0 && (
                <div class="card-footer">
                  <div class="card-tags">
                    {recette.data.tags.slice(0, 2).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="color:var(--color-primary)"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              )}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  {cuisine.editorial && (
    <section class="pseo-editorial" aria-label={`À propos de la ${cuisine.title}`}>
      <div class="pseo-editorial-content" set:html={cuisine.editorial} />
    </section>
  )}

  <section class="pseo-tips" aria-labelledby="tips-heading">
    <h2 id="tips-heading" class="pseo-section-title">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><circle cx="12" cy="12" r="10"></circle><line
          x1="12"
          y1="8"
          x2="12"
          y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg
      >
      Astuces {cuisine.title}
    </h2>
    <ul class="pseo-tips-list">
      {
        cuisine.tips.map((tip) => (
          <li>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
            {tip}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="pseo-related-cuisines" aria-labelledby="cuisines-heading">
    <h2 id="cuisines-heading" class="pseo-section-title">Autres cuisines</h2>
    <div class="pseo-tags-grid">
      {
        allCuisines.map((c) => {
          const cSlug = normalizeCuisine(c!);
          if (cSlug === slug) return null;
          return (
            <a href={`/blog/recettes/cuisine/${cSlug}/`} class="pseo-tag-chip">
              {c}
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
