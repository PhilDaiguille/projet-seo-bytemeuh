---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { slugify } from "../../../../utils/seo";

export async function getStaticPaths() {
  const recettes = await getCollection("recettes");
  const categories = [
    ...new Set(recettes.map((r) => r.data.category).filter(Boolean)),
  ];

  return categories.map((category) => ({
    params: { slug: slugify(category!) },
    props: { categoryName: category! },
  }));
}

const { slug } = Astro.params;
const { categoryName } = Astro.props;

const recettes = await getCollection("recettes");
const filtered = recettes
  .filter((r) => slugify(r.data.category ?? "") === slug)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

if (filtered.length === 0) {
  return Astro.redirect("/blog/recettes/");
}

const SITE_URL = "https://bytemeuh.phildaiguille.fr";
const pageUrl = `${SITE_URL}/blog/recettes/categorie/${slug}/`;

const categoryData: Record<
  string,
  { title: string; intro: string; tips: string[]; editorial?: string }
> = {
  "plat-principal": {
    title: "Plats principaux",
    intro:
      "Les plats principaux sont le cœur de chaque repas — celui qui rassasie, nourrit et rappelle pourquoi on cuisine. Qu'il s'agisse d'un burger gourmet, d'un curry parfumé ou d'une ratatouille mijotée, le plat principal définit le menu. Chez Bytemeuh, nous le préparons toujours avec une protéine de qualité et des légumes de saison.",
    editorial: `
      <h2>Qu'est-ce qui fait un grand plat principal ?</h2>
      <p>Un plat principal réussi n'est pas simplement un plat qui nourrit — c'est un plat qui <strong>satisfait</strong>. Il réunit trois éléments fondamentaux : une protéine (viande, poisson, légumineuse ou tofu), un féculent (riz, pâtes, pain, pomme de terre) et des légumes. Cet équilibre n'est pas arbitraire : il répond aux besoins nutritionnels et gustatiifs d'un repas complet.</p>
      <p>La cuisson est l'étape qui fait la différence entre le bon et l'exceptionnel. Pour les viandes, la réaction de Maillard — cette caramélisation des protéines à haute température — crée cette croûte dorée qui concentre les saveurs. Pour les légumes, la cuisson juste (al dente pour les légumes croquants, fondant pour les mijotés) préserve textures et nutriments.</p>

      <h2>L'art de la mise en place</h2>
      <p>La <em>mise en place</em> — terme emprunté à la cuisine professionnelle — désigne la préparation de tous les ingrédients avant de commencer à cuisiner. C'est l'un des secrets les mieux gardés des cuisiniers professionnels, et l'habitude qui fait le plus défaut aux cuisiniers amateurs.</p>
      <p>Préparer tous ses légumes taillés, ses sauces mesurées, ses épices dosées avant de mettre le feu sous la première poêle transforme radicalement l'expérience de cuisine. Fini le stress de couper l'oignon alors que la viande brûle — tout est là, prêt. La cuisine devient un plaisir, pas une course.</p>

      <h2>Les plats principaux chez Bytemeuh</h2>
      <p>Nos plats principaux couvrent tout le spectre : du burger gourmet au bœuf français aux currys de légumes indiens, en passant par les ratatouilles provençales et les poke bowls hawaïens. Dans chaque recette, nous précisons le niveau de difficulté, le temps de préparation et les astuces clés pour réussir le plat — même la première fois.</p>
    `,
    tips: [
      "Un plat principal se compose toujours de 3 éléments : protéine, féculent, légume",
      "La cuisson haute température (saisir, griller) crée la saveur — finissez au four",
      "Un bon plat se prépare en 2 temps : préparez tout, puis cuisinez",
    ],
  },
  "plat-vegan": {
    title: "Plats vegan",
    intro:
      "Les plats vegans démontrent qu'absence de produit animal ne signifie pas absence de goût. Le tofu absorbe les saveurs, les légumineuses créent du corps, les épices font voyager. Un burger végan bien préparé concurrence n'importe quel burger classique — et il digère mieux.",
    editorial: `
      <h2>Le vegan en cuisine : une créativité libérée</h2>
      <p>Cuisiner végan force à la créativité. Quand les protéines animales ne sont plus le pivot du plat, on redécouvre la richesse des légumineuses, la versatilité du tofu, la richesse umami des champignons, la générosité des céréales complètes. Des ingrédients qui existent depuis des millénaires dans les cuisines indienne, chinoise, moyen-orientale — cuisines où le végétalisme n'est pas une mode mais une tradition.</p>
      <p>Le <strong>tofu ferme</strong> est peut-être l'ingrédient vegan le plus polyvalent. Il absorbe toutes les marinades, prend toutes les textures (soyeux cru, croustillant frit, fondant poêlé), s'intègre dans toutes les cuisines. Le secret : ne jamais l'utiliser sans l'avoir préalablement mariné et pressé pour éliminer l'excès d'eau.</p>

      <h2>Les protéines végétales : diversité et complémentarité</h2>
      <p>L'une des idées reçues sur la cuisine végan est qu'elle manque de protéines. C'est faux — mais il faut comprendre comment les combiner. Les protéines végétales sont dites "incomplètes" parce qu'elles ne contiennent pas tous les acides aminés essentiels dans les bonnes proportions. La solution : les combiner.</p>
      <p>Riz + légumineuses (pois chiches, lentilles, haricots) forment un profil protéique complet. Ce mariage n'est pas une découverte moderne — il est au cœur de cuisines qui pratiquent le végétalisme depuis des siècles : le dal chawal indien (lentilles + riz), le houmous + pain pita libanais, les haricots noirs + tortillas mexicains.</p>

      <h2>Les plats vegans chez Bytemeuh</h2>
      <p>Nos recettes veganes sont pensées pour être satisfaisantes, gourmandes et reproductibles. Du burger vegan au jackfruit aux bao buns véganes en passant par les currys de pois chiches et les poke bowls au tofu, chaque plat est construit autour d'une combinaison protéique équilibrée et d'un soin particulier apporté à la texture et aux saveurs. Le vegan chez Bytemeuh n'est pas un compromis — c'est un choix délibéré et assumé.</p>
    `,
    tips: [
      "Texture et température sont les clés d'un bon plat végan : croquant + chaud",
      "La marinade fait toute la différence — minimum 1h, idéalement une nuit",
      "Combinez toujours féculents + légumineuses pour un profil protéique complet",
    ],
  },
  "street-food-vegetal": {
    title: "Street food végétal",
    intro:
      "La street food végétal reprend le meilleur de la cuisine de rue mondiale : bao buns chinois, tacos mexicains, bowls hawaïens — tous revisités sans produit animal. L'objectif ? Démocratiser une alimentation végétale en la rendant fun, accessible et réconfortante. Chaque plat est un concentré de culture et de technique.",
    editorial: `
      <h2>La street food végétale : un mouvement mondial</h2>
      <p>La street food végétale n'est pas une tendance récente — elle est au cœur des cuisines de rue asiatiques depuis des siècles. Les marchés de nuit taiwanais, les vendeurs ambulants indiens, les stands de falafels du Moyen-Orient : une grande partie de la street food mondiale a toujours été végétale par tradition, par économie ou par conviction religieuse.</p>
      <p>Ce qui est nouveau, c'est la <strong>visibilité</strong> de cette street food végétale en France, portée par une nouvelle génération de cuisiniers et de consommateurs qui cherchent une alimentation plus consciente sans sacrifier le plaisir et la convivialité. Le bao bun végane, le taco au jackfruit, le burger de haricots noirs — autant de plats qui font honneur à leurs traditions d'origine tout en proposant une alternative gourmande.</p>

      <h2>La texture : clé de voûte de la street food</h2>
      <p>La street food se mange debout, à la main, dans la rue. Elle doit donc être pratique à tenir, mais surtout <strong>satisfaisante texturalement</strong>. Le croquant, le fondant, le crémeux — ces contrastes de texture sont ce qui rend une bouchée mémorable. Un bao bun sans pickles croquants, c'est un bao bun monotone. Des tacos sans la fraîcheur du chou rouge, c'est des tacos qui s'effondrent texturalement.</p>
      <p>Pour la street food végétale, la texture est encore plus cruciale parce qu'on ne peut pas compter sur la richesse naturelle des protéines animales. Il faut la construire : tofu pressé et mariné pour la mâche, légumineuses croustillantes pour le croquant, avocat crémeux pour le fondant, pickles acidulés pour la fraîcheur.</p>

      <h2>La street food végétale chez Bytemeuh</h2>
      <p>Nous explorons la street food végétale à travers les traditions qui lui ont donné naissance. Nos bao buns au jackfruit s'inspirent directement des baozi chinois. Nos tacos au tofu fumé rendent hommage à la tradition mexicaine du taco al pastor. Nos poke bowls véganes célèbrent la fusion hawaïenne-japonaise. Dans chaque recette, nous expliquons la technique, les substitutions possibles et les astuces pour reproduire la magie de la street food chez soi.</p>
    `,
    tips: [
      "La street food se mange avec les mains — travaillez la texture pour ce contexte",
      "Les pickles sont incontournables dans chaque bowl — préparez-les la veille",
      "La vapeur est votre meilleur allié : bao buns, dim sum, gyoza",
    ],
  },
  "salade-vegetalienne": {
    title: "Salades végétariennes",
    intro:
      "Les salades ne sont pas une option — elles sont un art. Une bonne salade combine textures (croquant, fondant), températures (chaud-froid), et saveurs (acide, doux, amer). La vinaigrette fait 80% du travail : équilibre huile-acide-sel. Chez Bytemeuh, nous croyons que la meilleure vinaigrette est celle qui met en valeur les légumes, pas celle qui les masque.",
    editorial: `
      <h2>La salade : un plat à part entière</h2>
      <p>La salade a longtemps souffert d'une mauvaise réputation : synonyme de régime, de contrainte, de repas triste. Cette réputation est injuste — elle vient d'une mauvaise exécution. Une vraie salade végétarienne, bien composée, est l'un des plats les plus satisfaisants qui soit. Fraîche, colorée, texturée, parfumée : elle célèbre les légumes dans leur meilleure expression.</p>
      <p>Le secret d'une bonne salade végétarienne ? La <strong>composition en couches</strong>. Une base (feuilles, céréales, légumineuses). Une protéine végétale (œuf mollet, fromage, pois chiches rôtis). Des éléments de texture (noix, graines, croûtons). Des éléments de couleur et de fraîcheur (herbes fraîches, légumes crus). Et une vinaigrette qui lie le tout sans noyer les saveurs individuelles.</p>

      <h2>La vinaigrette : l'âme de la salade</h2>
      <p>La vinaigrette est le chef d'orchestre de la salade. Elle doit être émulsionnée — c'est-à-dire que l'huile et le vinaigre, naturellement antagonistes, doivent être liés en une préparation homogène. Pour ce faire : ajoutez le vinaigre avec la moutarde et le sel dans un bol, puis incorporez l'huile en filet fin en fouettant énergiquement. La moutarde joue le rôle d'émulsifiant — elle contient des molécules qui s'accrochent à la fois à l'eau et à l'huile.</p>
      <p>La règle de base : <strong>3 parts d'huile pour 1 part de vinaigre</strong>. Cette proportion peut varier selon l'acidité du vinaigre (vinaigre balsamique = plus sucré = 2:1, vinaigre de vin rouge = 3:1). Goûtez et ajustez : une vinaigrette doit être assez acide pour "réveiller" les légumes, pas assez pour les assécher.</p>

      <h2>Les salades végétariennes chez Bytemeuh</h2>
      <p>Nos salades végétariennes sont pensées comme des plats complets. Chaque recette contient une source de protéines (fromage de chèvre, œuf, légumineuses), une source de bons gras (avocat, noix, huile d'olive), et une source de glucides complexes (quinoa, boulgour, pois chiches). Elles se suffisent à elles-mêmes — aucun besoin d'un plat principal en accompagnement. De la salade César végétarienne à la salade de quinoa méditerranéenne, chaque recette est une invitation à redécouvrir ce que peut être une vraie salade.</p>
    `,
    tips: [
      "La vinaigrette se fait émulsifier — mixez ou secouez pour lier huile et vinaigre",
      "Ajoutez les feuilles au dernier moment pour éviter qu'elles flétrissent",
      "Un peu de fromage (feta, chèvre) transforme une salade en plat complet",
    ],
  },
};

const category = categoryData[slug!] ?? {
  title: categoryName,
  intro: `Découvrez nos recettes ${categoryName.toLowerCase()}. Des plats savoureux préparés avec des produits de ferme Bytemeuh.`,
  tips: [
    "Utilisez des ingrédients de qualité pour des résultats optimaux",
    "Adaptez les quantités selon le nombre de personnes",
    "N'hésitez pas à ajuster les épices selon vos goûts",
  ],
};

const allCategories = [
  ...new Set(recettes.map((r) => r.data.category).filter(Boolean)),
];

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      name: `${category.title} — Bytemeuh`,
      description: category.intro,
      url: pageUrl,
      mainEntity: {
        "@type": "ItemList",
        itemListElement: filtered.map((r, i) => ({
          "@type": "ListItem",
          position: i + 1,
          url: `${SITE_URL}/blog/recettes/${r.id}/`,
        })),
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: `${SITE_URL}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: `${SITE_URL}/blog/`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: "Recettes",
          item: `${SITE_URL}/blog/recettes/`,
        },
        {
          "@type": "ListItem",
          position: 4,
          name: "Catégories",
          item: `${SITE_URL}/blog/recettes/categorie/`,
        },
        {
          "@type": "ListItem",
          position: 5,
          name: category.title,
          item: pageUrl,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${category.title} — Bytemeuh`}
  description={category.intro.slice(0, 155)}
  canonical={pageUrl}
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/">Blog</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/recettes/">Recettes</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/recettes/categorie/">Catégories</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li aria-current="page">{category.title}</li>
    </ol>
  </nav>

  <header class="pseo-header">
    <span class="pseo-badge">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><rect x="3" y="3" width="7" height="7"></rect><rect
          x="14"
          y="3"
          width="7"
          height="7"></rect><rect x="14" y="14" width="7" height="7"
        ></rect><rect x="3" y="14" width="7" height="7"></rect></svg
      >
      Catégorie
    </span>
    <h1>{category.title}</h1>
    <p class="pseo-intro">{category.intro}</p>
  </header>

  <section class="pseo-recipes">
    <div class="cards-grid">
      {
        filtered.map((recette) => (
          <article class="card">
            <a
              href={`/blog/recettes/${recette.id}/`}
              aria-label={`Recette : ${recette.data.title}`}
            >
              <div class="card-image">
                {recette.data.featuredImage && (
                  <Image
                    src={recette.data.featuredImage}
                    alt={recette.data.featuredImageAlt ?? recette.data.title}
                    width={400}
                    height={267}
                    loading="lazy"
                    quality={70}
                    decoding="async"
                  />
                )}
                <span class="card-badge badge-recipe">Recette</span>
              </div>
              <div class="card-body">
                <div class="card-meta">
                  {recette.data.totalTime && (
                    <span class="card-meta-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>
                      {recette.data.totalTime
                        .replace("PT", "")
                        .replace("H", " h ")
                        .replace("M", " min")
                        .trim()}
                    </span>
                  )}
                  {recette.data.difficulty && (
                    <span class="card-meta-item">
                      {recette.data.difficulty}
                    </span>
                  )}
                  {recette.data.aggregateRating && (
                    <span class="card-meta-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="#f59e0b"
                        stroke="#f59e0b"
                        stroke-width="1"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                      </svg>
                      {recette.data.aggregateRating.ratingValue}
                    </span>
                  )}
                </div>
                <h2 class="card-title">{recette.data.title}</h2>
                <p class="card-description">{recette.data.description}</p>
              </div>
              {recette.data.tags && recette.data.tags.length > 0 && (
                <div class="card-footer">
                  <div class="card-tags">
                    {recette.data.tags.slice(0, 2).map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="color:var(--color-primary)"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              )}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  {category.editorial && (
    <section class="pseo-editorial" aria-label={`À propos de la catégorie ${category.title}`}>
      <div class="pseo-editorial-content" set:html={category.editorial} />
    </section>
  )}

  <section class="pseo-tips">
    <h2 id="tips-heading" class="pseo-section-title">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><circle cx="12" cy="12" r="10"></circle><line
          x1="12"
          y1="8"
          x2="12"
          y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg
      >
      Astuces {category.title}
    </h2>
    <ul class="pseo-tips-list">
      {
        category.tips.map((tip) => (
          <li>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="9 18 15 12 9 6" />
            </svg>
            {tip}
          </li>
        ))
      }
    </ul>
  </section>

  <section class="pseo-related-cuisines">
    <h2 id="cats-heading" class="pseo-section-title">Autres catégories</h2>
    <div class="pseo-tags-grid">
      {
        allCategories.map((c) => {
          const cSlug = slugify(c!);
          if (cSlug === slug) return null;
          return (
            <a
              href={`/blog/recettes/categorie/${cSlug}/`}
              class="pseo-tag-chip"
            >
              {c}
            </a>
          );
        })
      }
    </div>
  </section>
</BaseLayout>
