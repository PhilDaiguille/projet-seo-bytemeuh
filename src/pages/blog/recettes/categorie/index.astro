---
import { getCollection } from "astro:content";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { slugify } from "../../../../utils/seo";

const recettes = await getCollection("recettes");
const categories = [
  ...new Set(recettes.map((r) => r.data.category).filter(Boolean)),
];

const SITE_URL = "https://bytemeuh.phildaiguille.fr";

const categoryDescriptions: Record<string, string> = {
  "Plat principal":
    "Les grands plats qui rassasient et définissent le repas : burgers, currys, ratatouilles et bien plus.",
  "Plat vegan":
    "Des plats véganes gourmands et protéinés, qui prouvent qu'on ne manque de rien sans produit animal.",
  "Street food végétal":
    "La cuisine de rue mondiale revisitée sans produit animal : bao buns, tacos, bowls.",
  "Salade végétarienne":
    "Des salades complètes et généreuses, pensées comme des plats à part entière.",
};

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      name: "Recettes par catégorie — Bytemeuh",
      description:
        "Explorez nos recettes par type : plats principaux, plats vegans, street food, salades. Trouvez le plat qui vous correspond.",
      url: `${SITE_URL}/blog/recettes/categorie/`,
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: `${SITE_URL}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: `${SITE_URL}/blog/`,
        },
        {
          "@type": "ListItem",
          position: 3,
          name: "Recettes",
          item: `${SITE_URL}/blog/recettes/`,
        },
        {
          "@type": "ListItem",
          position: 4,
          name: "Catégories",
          item: `${SITE_URL}/blog/recettes/categorie/`,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Recettes par catégorie — Bytemeuh"
  description="Explorez nos recettes par type de plat : plats principaux, vegan, street food et salades. Chaque catégorie révèle une approche culinaire différente."
  canonical={`${SITE_URL}/blog/recettes/categorie/`}
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/">Blog</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/blog/recettes/">Recettes</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li aria-current="page">Catégories</li>
    </ol>
  </nav>

  <header class="pseo-header">
    <span class="pseo-badge">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><rect x="3" y="3" width="7" height="7"></rect><rect
          x="14"
          y="3"
          width="7"
          height="7"></rect><rect x="14" y="14" width="7" height="7"
        ></rect><rect x="3" y="14" width="7" height="7"></rect></svg
      >
      Types de plats
    </span>
    <h1>Recettes par catégorie</h1>
    <p class="pseo-intro">
      Chaque catégorie raconte une philosophy de cuisine. Les plats principaux
      nourrissent, les vegan révèlent les protéines végétales, la street food
      célèbre le fun, les salades prouvent que léger peut rimer avec délicieux.
    </p>
  </header>

  <div
    class="pseo-grid"
    style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-6); margin: var(--space-8) 0;"
  >
    {
      categories.map((cat) => {
        const slug = slugify(cat!);
        const count = recettes.filter(
          (r) => slugify(r.data.category ?? "") === slug,
        ).length;
        return (
          <a
            href={`/blog/recettes/categorie/${slug}/`}
            style="background: var(--color-surface); border-radius: var(--radius-lg); padding: var(--space-6); text-decoration: none; border: 1px solid var(--color-border); transition: all 0.2s ease; display: flex; flex-direction: column; gap: var(--space-3);"
          >
            <span style="font-weight: 700; color: var(--color-text); font-size: var(--text-lg);">
              {cat}
            </span>
            <p style="font-size: var(--text-sm); color: var(--color-muted); flex: 1;">
              {categoryDescriptions[cat!] ??
                `${count} recette${count > 1 ? "s" : ""}`}
            </p>
            <span style="font-size: var(--text-sm); color: var(--color-primary); font-weight: 600;">
              {count} recette{count > 1 ? "s" : ""} →
            </span>
          </a>
        );
      })
    }
  </div>

  <div
    style="margin-top: var(--space-10); padding: var(--space-8); background: var(--color-surface); border-radius: var(--radius-lg); border: 1px solid var(--color-border);"
  >
    <h2
      style="font-size: var(--text-xl); font-weight: 800; margin-bottom: var(--space-4);"
    >
      Comment choisir sa catégorie ?
    </h2>
    <p
      style="color: var(--color-muted); margin-bottom: var(--space-4); line-height: 1.65;"
    >
      Les <strong>plats principaux</strong> sont faits pour nourrir complètement —
      ils associent toujours protéine, féculent et légumes de saison. Les <strong
        >plats vegans</strong
      > prouvent qu'une cuisine sans produit animal peut être gourmande et satisfaisante
      : tofu mariné, légumineuses créatives, épices du monde. La <strong
        >street food végétale</strong
      > reprend les codes de la cuisine de rue internationale — bao buns, tacos, bowls
      — revisités sans compromis sur le goût. Enfin, les <strong
        >salades végétariennes</strong
      > sont des plats complets en elles-mêmes, avec une source de protéines, de bons
      gras et des herbes fraîches.
    </p>
    <p style="color: var(--color-muted); line-height: 1.65;">
      Chez Bytemeuh, chaque catégorie est pensée comme une philosophie culinaire
      à part entière — pas seulement un filtre de recherche. Explorez, essayez,
      adaptez : c'est comme ça qu'on apprend à cuisiner.
    </p>
  </div>
</BaseLayout>
