---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

const recettes = await getCollection("recettes");
const articles = await getCollection("articles");

const sortedRecettes = recettes.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const sortedArticles = articles.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: "https://bytemeuh.phildaiguille.fr/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Blog",
          item: "https://bytemeuh.phildaiguille.fr/blog/",
        },
      ],
    },
  ],
};
---

<BaseLayout
  title="Blog Bytemeuh — Recettes & articles durables"
  description="Explorez le blog Bytemeuh : recettes saines et gourmandes, articles sur la biotechnologie agricole, l'élevage intelligent et l'alimentation responsable."
  canonical="https://bytemeuh.phildaiguille.fr/blog/"
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li aria-current="page">Blog</li>
    </ol>
  </nav>

  <div style="margin-bottom: var(--space-10);">
    <h1
      style="font-size: var(--text-4xl); margin-bottom: var(--space-3); letter-spacing: -0.03em;"
    >
      Blog Bytemeuh
    </h1>
    <p
      style="font-size: var(--text-lg); color: var(--color-muted); max-width: 60rem;"
    >
      Découvrez nos recettes saines et nos articles sur l'agriculture durable,
      la biotechnologie et l'alimentation responsable.
    </p>
  </div>

  <section class="section" aria-labelledby="blog-recettes-heading">
    <div class="section-header">
      <h2 class="section-title" id="blog-recettes-heading">
        <span class="section-title-accent" aria-hidden="true"></span>
        Nos recettes
      </h2>
      <a
        href="/blog/recettes/"
        class="section-link"
        aria-label="Voir toutes les recettes"
      >
        Toutes les recettes
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
            points="12 5 19 12 12 19"></polyline></svg
        >
      </a>
    </div>
    <div class="cards-grid">
      {
        sortedRecettes.map((recette) => (
          <article class="card">
            <a
              href={`/blog/recettes/${recette.id}/`}
              aria-label={`Recette : ${recette.data.title}`}
            >
              <div class="card-image">
                {recette.data.featuredImage && (
                  <Image
                    src={recette.data.featuredImage}
                    alt={recette.data.featuredImageAlt ?? recette.data.title}
                    width={400}
                    height={267}
                    loading="lazy"
                    quality={82}
                    decoding="async"
                  />
                )}
                <span class="card-badge badge-recipe">Recette</span>
              </div>
              <div class="card-body">
                <div class="card-meta">
                  {recette.data.totalTime && (
                    <span class="card-meta-item">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <polyline points="12 6 12 12 16 14" />
                      </svg>
                      {recette.data.totalTime
                        .replace("PT", "")
                        .replace("H", " h ")
                        .replace("M", " min")
                        .trim()}
                    </span>
                  )}
                  {recette.data.difficulty && (
                    <span class="card-meta-item">
                      {recette.data.difficulty}
                    </span>
                  )}
                </div>
                <h3 class="card-title">{recette.data.title}</h3>
                <p class="card-description">{recette.data.description}</p>
              </div>
              {recette.data.tags && recette.data.tags.length > 0 && (
                <div class="card-footer">
                  <div class="card-tags">
                    {recette.data.tags.slice(0, 2).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="color:var(--color-primary)"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              )}
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section" aria-labelledby="blog-articles-heading">
    <div class="section-header">
      <h2 class="section-title" id="blog-articles-heading">
        <span class="section-title-accent" aria-hidden="true"></span>
        Nos articles
      </h2>
      <a
        href="/blog/articles/"
        class="section-link"
        aria-label="Voir tous les articles"
      >
        Tous les articles
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
            points="12 5 19 12 12 19"></polyline></svg
        >
      </a>
    </div>
    <div class="cards-grid">
      {
        sortedArticles.map((article) => (
          <article class="card">
            <a
              href={`/blog/articles/${article.id}/`}
              aria-label={`Article : ${article.data.title}`}
            >
              <div class="card-image">
                {article.data.featuredImage && (
                  <Image
                    src={article.data.featuredImage}
                    alt={article.data.featuredImageAlt ?? article.data.title}
                    width={400}
                    height={267}
                    loading="lazy"
                    quality={82}
                    decoding="async"
                  />
                )}
                <span class="card-badge badge-article">Article</span>
              </div>
              <div class="card-body">
                <div class="card-meta">
                  <span class="card-meta-item">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <>
                        <rect
                          x="3"
                          y="4"
                          width="18"
                          height="18"
                          rx="2"
                          ry="2"
                        />
                        <line x1="16" y1="2" x2="16" y2="6" />
                        <line x1="8" y1="2" x2="8" y2="6" />
                        <line x1="3" y1="10" x2="21" y2="10" />
                      </>
                    </svg>
                    {article.data.publishDate.toLocaleDateString("fr-FR", {
                      month: "short",
                      year: "numeric",
                    })}
                  </span>
                  {article.data.category && (
                    <span class="card-meta-item">{article.data.category}</span>
                  )}
                </div>
                <h3 class="card-title">{article.data.title}</h3>
                <p class="card-description">{article.data.description}</p>
              </div>
              {article.data.tags && article.data.tags.length > 0 && (
                <div class="card-footer">
                  <div class="card-tags">
                    {article.data.tags.slice(0, 2).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="color:var(--color-primary)"
                    aria-hidden="true"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              )}
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
