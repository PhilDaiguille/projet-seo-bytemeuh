---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { authors, authorUrl, resolveAuthor } from "../../data/authors";

export async function getStaticPaths() {
  return Object.values(authors).map((author) => ({
    params: { slug: author.slug },
    props: { author },
  }));
}

const { author } = Astro.props;

const SITE_URL = "https://bytemeuh.phildaiguille.fr";
const pageUrl = authorUrl(author);

// Publications attribuées à cet auteur
const allArticles = await getCollection("articles");
const allRecettes = await getCollection("recettes");

const articles = allArticles
  .filter((a) => resolveAuthor(a.data.author, "articles").slug === author.slug)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const recettes = allRecettes
  .filter((r) => resolveAuthor(r.data.author, "recettes").slug === author.slug)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const person = {
  "@type": "Person",
  "@id": `${pageUrl}#person`,
  name: author.name,
  url: pageUrl,
  image: author.imageUrl,
  jobTitle: author.jobTitle,
  description: author.bio,
  worksFor: {
    "@type": "Organization",
    name: "Bytemeuh",
    url: SITE_URL,
  },
  ...(author.sameAs.length > 0 ? { sameAs: author.sameAs } : {}),
};

const graph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      mainEntity: person,
      url: pageUrl,
      name: `${author.name} — ${author.jobTitle}`,
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Accueil",
          item: `${SITE_URL}/`,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Auteurs",
          item: `${SITE_URL}/auteurs/`,
        },
        { "@type": "ListItem", position: 3, name: author.name, item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${author.name} — ${author.short}`}
  description={author.metaDescription}
  canonical={pageUrl}
  ogImage={author.imageUrl}
  ogImageAlt={`Photo de ${author.name}`}
  graph={graph}
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li><a href="/auteurs/">Auteurs</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="9 18 15 12 9 6"></polyline></svg
        >
      </li>
      <li aria-current="page">{author.name}</li>
    </ol>
  </nav>

  <article class="surface" style="margin-bottom: var(--space-6);">
    <header
      style="display:flex;gap:var(--space-6);align-items:center;flex-wrap:wrap;margin-bottom:var(--space-6);"
    >
      <Image
        src={author.image}
        alt={`Photo de ${author.name}`}
        width={120}
        height={120}
        loading="eager"
        decoding="async"
        style="border-radius:50%;object-fit:cover;"
      />
      <div>
        <h1
          style="font-size: var(--text-4xl); margin-bottom: var(--space-2); letter-spacing: -0.03em;"
        >
          {author.name}
        </h1>
        <p style="color: var(--color-primary); font-weight: 700;">
          {author.jobTitle}
        </p>
      </div>
    </header>

    <div class="article-content">
      <p>{author.bio}</p>
    </div>

    {
      recettes.length > 0 && (
        <section style="margin-top: var(--space-8);">
          <h2>Recettes de {author.name}</h2>
          <ul>
            {recettes.map((r) => (
              <li>
                <a href={`/blog/recettes/${r.id}/`}>{r.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      articles.length > 0 && (
        <section style="margin-top: var(--space-8);">
          <h2>Articles de {author.name}</h2>
          <ul>
            {articles.map((a) => (
              <li>
                <a href={`/blog/articles/${a.id}/`}>{a.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>
