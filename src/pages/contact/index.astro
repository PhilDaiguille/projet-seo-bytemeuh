---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Bytemeuh — Nous contacter"
  description="Contactez l'équipe Bytemeuh pour toute question sur nos recettes, notre ferme ou nos partenariats. Nous sommes à votre disposition."
  canonical="https://bytemeuh.phildaiguille.fr/contact/"
>
  <nav aria-label="Fil d'ariane" class="breadcrumb">
    <ol>
      <li><a href="/">Accueil</a></li>
      <li aria-hidden="true" class="breadcrumb-sep">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </li>
      <li aria-current="page">Contact</li>
    </ol>
  </nav>

  <section class="surface">
    <h1 style="font-size: var(--text-4xl); margin-bottom: var(--space-4); letter-spacing: -0.03em;">Contactez-nous</h1>
    <p style="font-size: var(--text-lg); color: var(--color-muted); margin-bottom: var(--space-8); max-width: 55rem;">
      Vous avez une question sur nos recettes, notre ferme ou souhaitez établir un partenariat ? N'hésitez pas à nous contacter.
    </p>

    <div class="expertise-grid">
      <div class="expertise-card">
        <div class="expertise-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <p class="expertise-title">Par email</p>
        <p class="expertise-desc">contact@bytemeuh.phildaiguille.fr</p>
      </div>
      <div class="expertise-card">
        <div class="expertise-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <p class="expertise-title">Localisation</p>
        <p class="expertise-desc">Paris, France</p>
      </div>
      <div class="expertise-card">
        <div class="expertise-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <p class="expertise-title">Disponibilité</p>
        <p class="expertise-desc">Du lundi au vendredi, 9h — 18h</p>
      </div>
    </div>
  </section>
</BaseLayout>
