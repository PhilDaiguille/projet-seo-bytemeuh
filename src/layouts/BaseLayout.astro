---
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import logoImg from "../assets/images/bytemeuh.webp";
import "../styles/global.css";
const allArticles = await getCollection("articles");
const featuredArticles = allArticles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const allRecettes = await getCollection("recettes");
const featuredRecette = allRecettes[0];

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  ogImageAlt?: string;
  article?: {
    publishedTime?: Date | string;
    tags?: string[];
    section?: string;
  };
  noindex?: boolean;
  graph?: Record<string, unknown> | null;
}

const {
  title,
  description,
  canonical,
  ogType = "website",
  ogImage,
  ogImageAlt,
  article,
  noindex = false,
  graph,
} = Astro.props;

const SITE_NAME = "Bytemeuh";
const SITE_URL = "https://bytemeuh.phildaiguille.fr";

const slug = Astro.url.pathname.replace(/^\/|\/$/g, "");
const derivedOgImage = ogImage ?? `${SITE_URL}/assets/images/background.webp`;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      rel="preload"
      href="/assets/fonts/Montserrat-VariableFont_wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://analytics.phildaiguille.fr" />
    <Seo
      title={title}
      titleTemplate={`%s | ${SITE_NAME}`}
      description={description}
      canonical={canonical}
      ogType={ogType}
      ogImage={derivedOgImage}
      ogImageAlt={ogImageAlt ?? title}
      ogImageWidth={1200}
      ogImageHeight={675}
      siteName={SITE_NAME}
      locale="fr_FR"
      twitter={{ card: "summary_large_image" }}
      article={article}
      noindex={noindex}
      graph={graph}
      extraMeta={[
        { name: "twitter:title", content: `${title} | ${SITE_NAME}` },
        ...(description
          ? [{ name: "twitter:description", content: description }]
          : []),
        { name: "twitter:image", content: derivedOgImage },
        { name: "twitter:image:alt", content: ogImageAlt ?? title },
      ]}
      extraLinks={[
        {
          rel: "icon",
          type: "image/svg+xml",
          href: "/assets/static/favicon.svg",
        },
        {
          rel: "icon",
          type: "image/png",
          sizes: "32x32",
          href: "/assets/static/favicon-32x32.png",
        },
        {
          rel: "apple-touch-icon",
          sizes: "180x180",
          href: "/assets/static/apple-touch-icon.png",
        },
        { rel: "manifest", href: "/site.webmanifest" },
        { rel: "sitemap", href: "/sitemap-index.xml" },
        {
          rel: "alternate",
          type: "application/rss+xml",
          href: "/rss.xml",
          title: "Bytemeuh RSS",
        },
      ]}
    />

    <!-- Umami Analytics -->
    <script
      defer
      src="https://analytics.phildaiguille.fr/script.js"
      data-website-id="f6d2bfab-2762-462a-abe6-5b1a9e7c5b25"
      data-performance="true"
      is:inline></script>
  </head>
  <body>
    <!-- HEADER -->
    <header class="site-header" id="site-header">
      <div class="header-inner">
        <!-- Logo -->
        <a
          href="/"
          class="site-logo"
          aria-label="Bytemeuh — Retour à l'accueil"
        >
          <Image
            src={logoImg}
            alt="Logo Bytemeuh"
            width={40}
            height={40}
            quality={55}
            loading="eager"
            decoding="async"
          />
          <span class="logo-text">Bytemeuh</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="site-nav" aria-label="Navigation principale">
          <a href="/" class={`nav-link${currentPath === "/" ? " active" : ""}`}
            >Accueil</a
          >
          <a
            href="/blog/"
            class={`nav-link${currentPath.startsWith("/blog/") ? " active" : ""}`}
            >Blog</a
          >
          <a
            href="/blog/recettes/"
            class={`nav-link${currentPath.startsWith("/blog/recettes") ? " active" : ""}`}
            >Recettes</a
          >
          <a
            href="/blog/articles/"
            class={`nav-link${currentPath.startsWith("/blog/articles") ? " active" : ""}`}
            >Articles</a
          >
          <a
            href="/a-propos-de-nous/"
            class={`nav-link${currentPath.startsWith("/a-propos") ? " active" : ""}`}
            >À propos</a
          >
          <a href="/contact/" class="nav-cta">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6.09 6.09l.98-.98a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            Contact
          </a>
        </nav>

        <!-- Mobile hamburger -->
        <button
          class="menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="Ouvrir le menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <!-- Mobile drawer -->
      <nav class="mobile-nav" id="mobile-nav" aria-label="Navigation mobile">
        <a href="/" class="mobile-nav-link">Accueil</a>
        <a href="/blog/" class="mobile-nav-link">Blog</a>
        <a href="/blog/recettes/" class="mobile-nav-link">Recettes</a>
        <a href="/blog/articles/" class="mobile-nav-link">Articles</a>
        <a href="/a-propos-de-nous/" class="mobile-nav-link">À propos</a>
        <a href="/contact/" class="mobile-nav-cta">Nous contacter</a>
      </nav>
    </header>

    <!-- MAIN -->
    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="site-footer" aria-label="Pied de page">
      <div class="footer-inner">
        <div class="footer-top">
          <!-- Brand col -->
          <div class="footer-brand">
            <a href="/" class="footer-logo" aria-label="Bytemeuh accueil">
              <Image
                src={logoImg}
                alt="Logo Bytemeuh"
                width={36}
                height={36}
                loading="lazy"
                decoding="async"
              />
              <span class="footer-logo-name">Bytemeuh</span>
            </a>
            <p class="footer-tagline">
              Ferme française engagée dans une agriculture durable, combinant
              innovation technologique et pratiques respectueuses de
              l'environnement.
            </p>
            <span class="footer-badge">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                ></path></svg
              >
              Agriculture durable
            </span>
          </div>

          <!-- Nav col -->
          <div>
            <p class="footer-col-title">Découvrir</p>
            <nav class="footer-links" aria-label="Navigation footer découvrir">
              <a href="/">Accueil</a>
              <a href="/blog/">Blog</a>
              <a href="/blog/recettes/">Recettes</a>
              <a href="/blog/articles/">Articles</a>
              <a href="/a-propos-de-nous/">À propos</a>
              <a href="/auteurs/">Auteurs</a>
            </nav>
          </div>

          <!-- Legal col -->
          <div>
            <p class="footer-col-title">Informations</p>
            <nav
              class="footer-links"
              aria-label="Navigation footer informations"
            >
              <a href="/contact/">Contact</a>
              <a href="/mention-legales/">Mentions légales</a>
              <a href="/rss.xml">Flux RSS</a>
              <a href="/sitemap-index.xml">Sitemap</a>
            </nav>
          </div>

          <!-- Thematic col -->
          <div>
            <p class="footer-col-title">Thématiques</p>
            <nav
              class="footer-links"
              aria-label="Navigation footer thématiques"
            >
              {
                featuredArticles
                  .slice(0, 2)
                  .map((article) => (
                    <a href={`/blog/articles/${article.id}/`}>
                      {article.data.category ?? "Article"}
                    </a>
                  ))
              }
              {
                featuredRecette && (
                  <a href={`/blog/recettes/${featuredRecette.id}/`}>Recette</a>
                )
              }
              <a href="/blog/articles/">Tous les articles</a>
            </nav>
          </div>
        </div>

        <div class="footer-bottom">
          <p class="footer-copyright">
            &copy; {new Date().getFullYear()} Bytemeuh — Tous droits réservés
          </p>
          <div class="footer-legal">
            <a href="/mention-legales/">Mentions légales</a>
            <a href="/contact/">Contact</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Header scroll effect + mobile menu -->
    <script is:inline>
      const header = document.getElementById("site-header");
      const toggle = document.querySelector(".menu-toggle");
      const mobileNav = document.getElementById("mobile-nav");

      // Scroll shadow
      const observer = new IntersectionObserver(
        ([e]) => header.classList.toggle("scrolled", !e.isIntersecting),
        { rootMargin: "-1px 0px 0px 0px", threshold: [1] },
      );
      const sentinel = document.createElement("div");
      sentinel.style.cssText =
        "position:absolute;top:0;left:0;width:1px;height:1px;pointer-events:none";
      document.body.prepend(sentinel);
      observer.observe(sentinel);

      // Mobile toggle
      if (toggle && mobileNav) {
        toggle.addEventListener("click", () => {
          const open = toggle.getAttribute("aria-expanded") === "true";
          toggle.setAttribute("aria-expanded", String(!open));
          mobileNav.classList.toggle("open", !open);
        });
      }
    </script>
  </body>
</html>
